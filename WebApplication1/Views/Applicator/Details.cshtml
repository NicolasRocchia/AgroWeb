@model WebApplication1.Models.Recipes.RecipeDetailViewModel
@{
    ViewData["Title"] = Model.Recipe.RfdNumber.HasValue ? $"Receta RFD #{Model.Recipe.RfdNumber}" : "Receta Manual";
}

<!-- Header Sticky -->
<div class="detail-header">
    <div class="detail-header-content">
        <a asp-action="Index" class="back-button">
            ← Volver a Mis Recetas
        </a>
        <h1 class="detail-title">
            @(Model.Recipe.RfdNumber.HasValue ? $"RFD #{Model.Recipe.RfdNumber}" : "Receta Manual")
        </h1>
        <div class="detail-meta">
            @{
                var statusClass = Model.Recipe.Status?.ToUpper() switch
                {
                                            "ABIERTA" => "status-draft",
                                            "PENDIENTE" => "status-pending",
                                            "APROBADA" => "status-approved",
                                            "RECHAZADA" => "status-rejected",
                                            "OBSERVADA" => "status-warning",
                                            "CERRADA" => "status-expired",
                                                    "CERRADA_MANUAL" => "status-expired",
                                            "ANULADA" => "status-rejected",
                    _ => "status-draft"
                };
            }
            <span class="status-badge @statusClass">
                @Model.Recipe.Status
            </span>
        </div>
    </div>
</div>

<!-- Contenido Principal -->
<div class="detail-container">

    @if (TempData["Success"] != null)
    {
        <div class="alert-success" style="background: #ecfdf5; border: 1px solid #6ee7b7; border-radius: 10px; padding: 14px 20px; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; color: #065f46;">
            <span>✅</span>
            <span>@TempData["Success"]</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert-error">
            <span class="alert-icon">⚠️</span>
            <div>
                <strong>Error:</strong> @TempData["Error"]
            </div>
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert-error">
            <span class="alert-icon">⚠️</span>
            <div>
                <strong>Error:</strong> @ViewBag.Error
            </div>
        </div>
    }

    <!-- Acciones de Estado -->
    @{
        var st = Model.Recipe.Status?.ToUpper();
    }
    @if (st == "ABIERTA" || st == "APROBADA" || st == "RECHAZADA" || st == "OBSERVADA")
    {
        <section class="detail-section" style="background: #f8fafc; border: 2px dashed #cbd5e1;">
            <h2 class="section-title">
                <span class="section-icon">⚡</span> Acciones
            </h2>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                @if (st == "ABIERTA")
                {
                    <a href="@Url.Action("AssignMunicipality", "Applicator", new { id = Model.Recipe.Id, code = Model.Recipe.PublicCode })"
                       class="btn-status" style="background: #eff6ff; color: #1e40af; border: 2px solid #93c5fd; text-decoration: none;">
                        📤 Enviar a Municipio
                    </a>
                    <form asp-action="ChangeStatus" method="post" style="margin: 0;"
                          onsubmit="return confirm('¿Cerrar esta receta manualmente?\n\nSi hay una ejecución en curso, se marcará como confirmada por el productor.');">
                        <input type="hidden" name="id" value="@Model.Recipe.Id" />
                        <input type="hidden" name="code" value="@Model.Recipe.PublicCode" />
                        <input type="hidden" name="status" value="CERRADA_MANUAL" />
                        <button type="submit" class="btn-status btn-cerrar">✅ Cerrar Receta</button>
                    </form>
                    <form asp-action="ChangeStatus" method="post" style="margin: 0;"
                          onsubmit="return confirm('¿Anular esta receta?\n\nSi hay una ejecución en curso, se cancelará.');">
                        <input type="hidden" name="id" value="@Model.Recipe.Id" />
                        <input type="hidden" name="code" value="@Model.Recipe.PublicCode" />
                        <input type="hidden" name="status" value="ANULADA" />
                        <button type="submit" class="btn-status btn-anular">❌ Anular Receta</button>
                    </form>
                }
                @if (st == "APROBADA")
                {
                    <form asp-action="ChangeStatus" method="post" style="margin: 0;"
                          onsubmit="return confirm('¿Confirmar que la aplicación fue realizada?\n\nSi hay una ejecución en curso, se marcará como confirmada por el productor.');">
                        <input type="hidden" name="id" value="@Model.Recipe.Id" />
                        <input type="hidden" name="code" value="@Model.Recipe.PublicCode" />
                        <input type="hidden" name="status" value="CERRADA_MANUAL" />
                        <button type="submit" class="btn-status btn-cerrar">✅ Cerrar Receta (Aplicada)</button>
                    </form>
                }
                @* ── Botones de ejecución: Asignar aplicador o Publicar trabajo ── *@
                @{
                    // Receta manual (sin RFD): puede ejecutarse si no está cerrada/anulada
                    // Receta formal (con RFD): solo si está aprobada
                    var isManual = !Model.Recipe.RfdNumber.HasValue;
                    var canExecute = (isManual && st != "CERRADA" && st != "ANULADA")
                    || st == "APROBADA";
                }
                @if (canExecute)
                {
                    <button type="button" class="btn-status" id="btnAssignApplicator"
                            style="background: #f0fdf4; color: #166534; border: 2px solid #86efac;"
                            onclick="toggleAssignPanel()">
                        🚜 Asignar Aplicador
                    </button>
                    <a href="@Url.Action("Create", "Jobs", new { recipeId = Model.Recipe.Id })"
                       class="btn-status"
                       style="background: #fefce8; color: #854d0e; border: 2px solid #fde047; text-decoration: none;">
                        📋 Publicar en Bolsa de Trabajo
                    </a>
                }
                @if (st == "RECHAZADA")
                {
                    <form asp-action="ChangeStatus" method="post" style="margin: 0;"
                          onsubmit="return confirm('¿Anular esta receta rechazada?');">
                        <input type="hidden" name="id" value="@Model.Recipe.Id" />
                        <input type="hidden" name="code" value="@Model.Recipe.PublicCode" />
                        <input type="hidden" name="status" value="ANULADA" />
                        <button type="submit" class="btn-status btn-anular">❌ Anular Receta</button>
                    </form>
                }
            </div>
        </section>
    }

    <!-- Ejecución activa (si existe) -->
    <div id="executionSection"></div>

    <!-- Panel de asignación directa de aplicador (colapsable) -->
    <section class="detail-section" id="assignPanel" style="display:none; border: 2px solid #86efac; background: #f0fdf4;">
        <h2 class="section-title">
            <span class="section-icon">🚜</span> Seleccionar Aplicador
        </h2>
        <div id="applicatorLoading" style="text-align:center; padding:20px; color:#888;">
            🔄 Cargando aplicadores verificados...
        </div>
        <div id="applicatorList" style="display:none;"></div>
        <div id="applicatorEmpty" style="display:none; text-align:center; padding:20px; color:#64748b;">
            <p>No hay aplicadores verificados disponibles.</p>
        </div>
    </section>

    <!-- Estado Municipal -->
    @if (Model.Recipe.AssignedMunicipalityId.HasValue)
    {
        <section class="detail-section" style="background: #eff6ff; border-left: 4px solid #3b82f6;">
            <h2 class="section-title">
                <span class="section-icon">🏛️</span> Control Municipal
            </h2>
            <div class="info-grid" style="grid-template-columns: 1fr 1fr;">
                <div class="info-item">
                    <span class="info-label">Municipio asignado</span>
                    <span class="info-value">@Model.Recipe.AssignedMunicipalityName</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Enviada el</span>
                    <span class="info-value">@DateHelper.FormatArg(Model.Recipe.AssignedAt)</span>
                </div>
            </div>

            @if (Model.Recipe.ReviewLogs?.Any() == true)
            {
                <h3 style="margin: 16px 0 8px; font-size: 14px; color: #475569;">Historial de revisiones</h3>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    @foreach (var log in Model.Recipe.ReviewLogs)
                    {
                        var actionColor = log.Action switch
                        {
                                                                            "APROBADA" => "#16a34a",
                                                                            "RECHAZADA" => "#dc2626",
                                                                            "OBSERVADA" => "#d97706",
                                                                            "REDIRIGIDA" => "#2563eb",
                            _ => "#64748b"
                        };
                        var actionIcon = log.Action switch
                        {
                                                                            "APROBADA" => "✅",
                                                                            "RECHAZADA" => "❌",
                                                                            "OBSERVADA" => "💬",
                                                                            "REDIRIGIDA" => "↪️",
                            _ => "•"
                        };
                        <div style="padding: 10px 14px; background: white; border-radius: 8px; border-left: 3px solid @actionColor;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="font-weight: 600; color: @actionColor;">@actionIcon @log.Action</span>
                                <span style="font-size: 12px; color: #94a3b8;">@DateHelper.FormatArg(log.CreatedAt)</span>
                            </div>
                            <div style="font-size: 13px; color: #64748b;">@log.MunicipalityName</div>
                            @if (log.Action == "REDIRIGIDA" && !string.IsNullOrEmpty(log.TargetMunicipalityName))
                            {
                                <div style="font-size: 13px; color: #2563eb;">→ @log.TargetMunicipalityName</div>
                            }
                            @if (!string.IsNullOrEmpty(log.Observation))
                            {
                                <div style="margin-top: 6px; font-size: 13px; color: #334155; background: #f8fafc; padding: 8px; border-radius: 6px;">@log.Observation</div>
                            }
                        </div>
                    }
                </div>
            }
        </section>
    }

    <!-- Mensajes -->
    @if (Model.Recipe.Messages?.Any() == true || st == "OBSERVADA" || st == "PENDIENTE")
    {
        <section class="detail-section">
            <h2 class="section-title">
                <span class="section-icon">💬</span> Mensajes
            </h2>

            @if (Model.Recipe.Messages?.Any() == true)
            {
                <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; max-height: 400px; overflow-y: auto;">
                    @foreach (var msg in Model.Recipe.Messages)
                    {
                        var isMe = msg.SenderRole == "Productor";
                        <div style="align-self: @(isMe ? "flex-end" : "flex-start"); max-width: 80%; padding: 10px 14px; border-radius: 12px; background: @(isMe ? "#dcfce7" : "#f1f5f9");">
                            <div style="font-size: 12px; font-weight: 600; color: @(isMe ? "#166534" : "#1e40af"); margin-bottom: 4px;">
                                @msg.SenderName (@msg.SenderRole)
                            </div>
                            <div style="font-size: 14px; color: #1e293b;">@msg.Message</div>
                            <div style="font-size: 11px; color: #94a3b8; text-align: right; margin-top: 4px;">
                                @DateHelper.FormatArg(msg.CreatedAt, "dd/MM HH:mm")
                            </div>
                        </div>
                    }
                </div>
            }

            @if (st == "OBSERVADA" || st == "PENDIENTE")
            {
                <form asp-action="SendMessage" method="post" style="display: flex; gap: 8px;">
                    <input type="hidden" name="id" value="@Model.Recipe.Id" />
                    <input type="hidden" name="code" value="@Model.Recipe.PublicCode" />
                    <input type="text" name="message" required maxlength="1000"
                           placeholder="Escribí un mensaje al municipio..."
                           style="flex: 1; padding: 10px 14px; border: 2px solid #e2e8f0; border-radius: 10px; font-size: 14px;" />
                    <button type="submit" class="btn-status btn-cerrar" style="white-space: nowrap;">
                        Enviar 📩
                    </button>
                </form>
                <p style="font-size: 12px; color: #94a3b8; margin-top: 6px;">
                    Tu mensaje será enviado al municipio para su revisión.
                </p>
            }
        </section>
    }

    <!-- Información General -->
    <section class="detail-section">
        <h2 class="section-title">
            <span class="section-icon">📄</span> Información General
        </h2>
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">Fecha de Emisión</span>
                <span class="info-value">@Model.Recipe.IssueDate.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="info-item">
                <span class="info-label">Inicio Posible</span>
                <span class="info-value @(Model.Recipe.PossibleStartDate == null ? "empty" : "")">
                    @(Model.Recipe.PossibleStartDate?.ToString("dd/MM/yyyy") ?? "No especificado")
                </span>
            </div>
            <div class="info-item">
                <span class="info-label">Fecha Recomendada</span>
                <span class="info-value @(Model.Recipe.RecommendedDate == null ? "empty" : "")">
                    @(Model.Recipe.RecommendedDate?.ToString("dd/MM/yyyy") ?? "No especificada")
                </span>
            </div>
            <div class="info-item">
                <span class="info-label">Fecha de Vencimiento</span>
                <span class="info-value @(Model.Recipe.ExpirationDate == null ? "empty" : "")">
                    @(Model.Recipe.ExpirationDate?.ToString("dd/MM/yyyy") ?? "No especificado")
                </span>
            </div>
            <div class="info-item">
                <span class="info-label">Tipo de Aplicación</span>
                <span class="info-value">@(Model.Recipe.ApplicationType ?? "No especificado")</span>
            </div>
            <div class="info-item">
                <span class="info-label">Cultivo</span>
                <span class="info-value">@(Model.Recipe.Crop ?? "No especificado")</span>
            </div>
            <div class="info-item">
                <span class="info-label">Superficie Unitaria</span>
                <span class="info-value">
                    @(Model.Recipe.UnitSurfaceHa.HasValue ? $"{Model.Recipe.UnitSurfaceHa:N2} ha" : "No especificada")
                </span>
            </div>
        </div>
    </section>

    <!-- Diagnóstico y Tratamiento -->
    @if (!string.IsNullOrEmpty(Model.Recipe.Diagnosis) || !string.IsNullOrEmpty(Model.Recipe.Treatment))
    {
        <section class="detail-section">
            <h2 class="section-title">
                <span class="section-icon">🔬</span> Diagnóstico y Tratamiento
            </h2>
            <div class="card-content">
                @if (!string.IsNullOrEmpty(Model.Recipe.Diagnosis))
                {
                    <p><strong>Diagnóstico:</strong></p>
                    <p style="white-space: pre-wrap; margin-left: 20px;">@Model.Recipe.Diagnosis</p>
                }
                @if (!string.IsNullOrEmpty(Model.Recipe.Treatment))
                {
                    <p><strong>Tratamiento:</strong></p>
                    <p style="white-space: pre-wrap; margin-left: 20px;">@Model.Recipe.Treatment</p>
                }
            </div>
        </section>
    }

    <!-- Solicitante -->
    <section class="detail-section">
        <h2 class="section-title">
            <span class="section-icon">👤</span> Solicitante
        </h2>
        <div class="card-content">
            <p><strong>Razón Social:</strong> @Model.Recipe.Requester.LegalName</p>
            <p><strong>CUIT:</strong> @Model.Recipe.Requester.TaxId</p>
        </div>
    </section>

    <!-- Asesor -->
    <section class="detail-section">
        <h2 class="section-title">
            <span class="section-icon">👨‍🔬</span> Asesor Fitosanitario
        </h2>
        <div class="card-content">
            <p><strong>Nombre Completo:</strong> @Model.Recipe.Advisor.FullName</p>
            <p><strong>Matrícula:</strong> @Model.Recipe.Advisor.LicenseNumber</p>
        </div>
    </section>

    <!-- Condiciones Ambientales -->
    @if (Model.Recipe.TempMin.HasValue || Model.Recipe.TempMax.HasValue ||
        Model.Recipe.HumidityMin.HasValue || Model.Recipe.HumidityMax.HasValue ||
        Model.Recipe.WindMinKmh.HasValue || Model.Recipe.WindMaxKmh.HasValue ||
        !string.IsNullOrEmpty(Model.Recipe.WindDirection))
    {
        <section class="detail-section">
            <h2 class="section-title">
                <span class="section-icon">🌤️</span> Condiciones Ambientales
            </h2>
            <div class="info-grid">
                @if (Model.Recipe.TempMin.HasValue || Model.Recipe.TempMax.HasValue)
                {
                    <div class="info-item">
                        <span class="info-label">Temperatura</span>
                        <span class="info-value">@Model.Recipe.TempMin°C - @Model.Recipe.TempMax°C</span>
                    </div>
                }
                @if (Model.Recipe.HumidityMin.HasValue || Model.Recipe.HumidityMax.HasValue)
                {
                    <div class="info-item">
                        <span class="info-label">Humedad</span>
                        <span class="info-value">@Model.Recipe.HumidityMin% - @Model.Recipe.HumidityMax%</span>
                    </div>
                }
                @if (Model.Recipe.WindMinKmh.HasValue || Model.Recipe.WindMaxKmh.HasValue)
                {
                    <div class="info-item">
                        <span class="info-label">Viento</span>
                        <span class="info-value">@Model.Recipe.WindMinKmh - @Model.Recipe.WindMaxKmh km/h</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Recipe.WindDirection))
                {
                    <div class="info-item">
                        <span class="info-label">Dirección del Viento</span>
                        <span class="info-value">@Model.Recipe.WindDirection</span>
                    </div>
                }
            </div>
        </section>
    }

    <!-- Pronóstico Climático -->
    @{
        ViewData["Recipe"] = Model.Recipe;
    }
    @await Html.PartialAsync("_WeatherForecast")

    <!-- Productos -->
    <section class="detail-section">
        <h2 class="section-title">
            <span class="section-icon">🧪</span> Productos (@Model.Recipe.Products.Count)
        </h2>

        @if (Model.Recipe.Products.Any())
        {
            <div class="products-container">
                @foreach (var product in Model.Recipe.Products)
                {
                    @await Html.PartialAsync("_ProductCard", product)
                }
            </div>
        }
        else
        {
            <div class="empty-state-detail">
                <div class="empty-icon-large">📦</div>
                <h3>No hay productos registrados</h3>
            </div>
        }
    </section>

    <!-- Lotes -->
    <section class="detail-section">
        <h2 class="section-title">
            <span class="section-icon">🗺️</span> Lotes (@Model.Recipe.Lots.Count)
        </h2>

        @if (Model.Recipe.Lots.Any())
        {
            <div class="lots-container">
                @foreach (var lot in Model.Recipe.Lots)
                {
                    <div class="lot-card">
                        <div class="lot-header">
                            <span class="lot-icon">📍</span>
                            @lot.LotName
                        </div>
                        <div class="lot-details">
                            @if (!string.IsNullOrEmpty(lot.Locality))
                            {
                                <p><strong>Localidad:</strong> @lot.Locality</p>
                            }
                            @if (!string.IsNullOrEmpty(lot.Department))
                            {
                                <p><strong>Departamento:</strong> @lot.Department</p>
                            }
                            @if (lot.SurfaceHa.HasValue)
                            {
                                <p><strong>Superficie:</strong> @lot.SurfaceHa.Value.ToString("N2") ha</p>
                            }
                            @if (lot.Vertices != null && lot.Vertices.Any())
                            {
                                <details style="margin-top: 8px;">
                                    <summary style="cursor: pointer; color: #667eea; font-weight: 600;">
                                        Ver @lot.Vertices.Count coordenadas
                                    </summary>
                                    <ul style="margin: 8px 0; padding-left: 20px; font-size: 13px;">
                                        @foreach (var vertex in lot.Vertices.OrderBy(v => v.Order))
                                        {
                                            <li>Punto @vertex.Order: @vertex.Latitude.ToString("F6"), @vertex.Longitude.ToString("F6")</li>
                                        }
                                    </ul>
                                </details>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state-detail">
                <div class="empty-icon-large">🗺️</div>
                <h3>No hay lotes registrados</h3>
            </div>
        }
    </section>

    <!-- Mapa Interactivo -->
    @await Html.PartialAsync("_RecipeMap")

    <!-- Notas -->
    @if (!string.IsNullOrEmpty(Model.Recipe.Notes))
    {
        <section class="detail-section">
            <h2 class="section-title">
                <span class="section-icon">📝</span> Notas
            </h2>
            <div class="card-content">
                <p style="white-space: pre-wrap;">@Model.Recipe.Notes</p>
            </div>
        </section>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/recipeDetail.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/recipes.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        var applicatorsLoaded = false;
        var applicatorsData = @Html.Raw(ViewBag.ApplicatorsJson ?? "[]");

        // ── Renderizar ejecución activa ──
        (function() {
            var execData = @Html.Raw(ViewBag.ExecutionJson ?? "null");
            if (!execData) return;

            var e = typeof execData === 'string' ? JSON.parse(execData) : execData;
            var section = document.getElementById('executionSection');

            var statusMap = {
                'PENDIENTE': { icon: '⏳', label: 'Pendiente', color: '#f59e0b', bg: '#fef3c7' },
                'ACEPTADA': { icon: '✅', label: 'Aceptada', color: '#3b82f6', bg: '#dbeafe' },
                'EN_CAMINO': { icon: '🚛', label: 'En camino', color: '#8b5cf6', bg: '#ede9fe' },
                'EN_CURSO': { icon: '🔄', label: 'En curso', color: '#10b981', bg: '#d1fae5' },
                'PAUSADA': { icon: '⏸️', label: 'Pausada', color: '#f97316', bg: '#fff7ed' },
                'COMPLETADA': { icon: '🏁', label: 'Completada', color: '#059669', bg: '#d1fae5' },
                'COMPLETADA_ADMIN': { icon: '✅', label: 'Confirmada por productor', color: '#0d9488', bg: '#ccfbf1' },
                'CANCELADA': { icon: '❌', label: 'Cancelada', color: '#ef4444', bg: '#fee2e2' }
            };

            var s = statusMap[e.status] || { icon: '❓', label: e.status, color: '#666', bg: '#f5f5f5' };

            var html = '<section class="detail-section" style="border: 2px solid ' + s.color + '; background: ' + s.bg + ';">';
            html += '<h2 class="section-title"><span class="section-icon">🚜</span> Ejecución en Campo</h2>';

            html += '<div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">';
            html += '<span style="font-size:1.3rem;">' + s.icon + '</span>';
            html += '<span style="font-weight:700; color:' + s.color + '; font-size:1.05rem;">' + s.label + '</span>';
            html += '</div>';

            html += '<div style="display:grid; grid-template-columns:1fr 1fr; gap:8px 20px; font-size:.9rem; color:#334155;">';
            if (e.applicatorBusinessName) html += '<div><strong>Aplicador:</strong> ' + e.applicatorBusinessName + '</div>';
            if (e.origin) html += '<div><strong>Origen:</strong> ' + (e.origin === 'BOLSA' ? '📋 Bolsa de trabajo' : '🎯 Asignación directa') + '</div>';

            var formatDate = function(d) { return d ? new Date(d).toLocaleDateString('es-AR', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '—'; };

            if (e.createdAt) html += '<div><strong>Creada:</strong> ' + formatDate(e.createdAt) + '</div>';
            if (e.startedAt) html += '<div><strong>Inicio:</strong> ' + formatDate(e.startedAt) + '</div>';
            if (e.completedAt) html += '<div><strong>Fin:</strong> ' + formatDate(e.completedAt) + '</div>';
            if (e.totalActiveMinutes) html += '<div><strong>Tiempo activo:</strong> ' + e.totalActiveMinutes + ' min</div>';
            html += '</div>';

            if (e.review) {
                var stars = '';
                for (var i = 0; i < e.review.rating; i++) stars += '★';
                html += '<div style="margin-top:12px; padding:10px; background:rgba(255,255,255,.6); border-radius:8px;">';
                html += '<span style="color:#f59e0b;">' + stars + '</span> <strong>' + e.review.rating + '/5</strong>';
                if (e.review.comment) html += ' — <em>"' + e.review.comment + '"</em>';
                html += '</div>';
            }

            html += '<div style="margin-top:12px;">';
            html += '<a href="/Executions/Detail/' + e.id + '" style="color:' + s.color + '; font-weight:600; text-decoration:none;">Ver detalle completo →</a>';
            html += '</div>';

            html += '</section>';
            section.innerHTML = html;
        })();

        function toggleAssignPanel() {
            var panel = document.getElementById('assignPanel');
            if (panel.style.display === 'none') {
                panel.style.display = '';
                if (!applicatorsLoaded) loadApplicators();
            } else {
                panel.style.display = 'none';
            }
        }

        function loadApplicators() {
            applicatorsLoaded = true;
            document.getElementById('applicatorLoading').style.display = 'none';

            var data = Array.isArray(applicatorsData) ? applicatorsData : [];
            if (data.length === 0) {
                document.getElementById('applicatorEmpty').style.display = '';
                return;
            }

            var listEl = document.getElementById('applicatorList');
            var html = '';

            data.forEach(function(a) {
                var machines = (a.machineTypes || []).join(', ') || 'No especificado';
                html += '<div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px; border-bottom:1px solid #e2e8f0;">';
                html += '<div>';
                html += '<strong>' + a.businessName + '</strong>';
                if (a.contactPhone) html += ' · <a href="tel:' + a.contactPhone + '">' + a.contactPhone + '</a>';
                html += '<br/><span style="font-size:0.85rem; color:#64748b;">🔧 ' + machines + '</span>';
                html += '</div>';
                html += '<form method="post" action="/Executions/CreateDirect" style="margin:0;">';
                html += '<input type="hidden" name="recipeId" value="@Model.Recipe.Id" />';
                html += '<input type="hidden" name="applicatorProfileId" value="' + a.id + '" />';
                html += '<button type="submit" onclick="return confirm(\'¿Asignar a ' + a.businessName.replace(/'/g, "\\'") + '?\')" ';
                html += 'style="background:#10b981; color:#fff; border:none; border-radius:8px; padding:8px 16px; font-weight:600; cursor:pointer;">Asignar</button>';
                html += '</form></div>';
            });

            listEl.innerHTML = html;
            listEl.style.display = '';
        }
    </script>
}
