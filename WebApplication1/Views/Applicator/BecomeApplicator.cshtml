@{
    ViewData["Title"] = "Registrarme como Aplicador";
}

<div class="page-container" style="max-width: 700px; margin: 0 auto; padding: 0 20px 40px;">
    <a asp-action="Index" asp-controller="Home" class="back-link">← Volver al Inicio</a>

    <div class="create-user-form">
        <div style="text-align: center; margin-bottom: 1.5rem;">
            <span style="font-size: 2.5rem;">🚜</span>
            <h2 style="margin: 0.5rem 0 0.25rem;">Registrarme como Aplicador</h2>
            <p style="color: #64748b; font-size: 0.9rem;">Completá los datos de tu empresa para ofrecer servicios de aplicación</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form method="post" id="applicatorForm">
            @Html.AntiForgeryToken()

            <div class="form-section">
                <h4 class="form-section-title">🏢 Datos de la Empresa</h4>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Razón Social *</label>
                        <input name="businessName" type="text" class="form-control"
                               placeholder="Fumigaciones del Sur S.R.L."
                               value="@ViewBag.BusinessName" required maxlength="200" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">CUIT Empresa *</label>
                        <input name="taxId" type="text" class="form-control"
                               placeholder="30712345678"
                               value="@ViewBag.TaxId" required
                               pattern="\d{10,11}" title="10 u 11 dígitos sin guiones" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Teléfono de contacto <span class="optional-tag">(opcional)</span></label>
                        <input name="contactPhone" type="tel" class="form-control"
                               placeholder="3464 654321" value="@ViewBag.ContactPhone" maxlength="30" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email de contacto <span class="optional-tag">(opcional)</span></label>
                        <input name="contactEmail" type="email" class="form-control"
                               placeholder="contacto@@empresa.com" value="@ViewBag.ContactEmail" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Descripción del servicio <span class="optional-tag">(opcional)</span></label>
                    <textarea name="description" class="form-control" rows="2"
                              placeholder="Breve descripción de tus servicios, experiencia, etc."
                              maxlength="500">@ViewBag.Description</textarea>
                </div>
            </div>

            <div class="form-section">
                <h4 class="form-section-title">🔧 Maquinaria Disponible</h4>
                <p style="color: #64748b; font-size: 0.85rem; margin-bottom: 0.75rem;">
                    Seleccioná los tipos de maquinaria que tenés disponible:
                </p>
                <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                    <label class="machine-chip"><input type="checkbox" class="machine-check" value="drone" /> 🛸 Drone</label>
                    <label class="machine-chip"><input type="checkbox" class="machine-check" value="mosquito" /> 🦟 Mosquito</label>
                    <label class="machine-chip"><input type="checkbox" class="machine-check" value="arrastre" /> 🚜 Arrastre</label>
                    <label class="machine-chip"><input type="checkbox" class="machine-check" value="autopropulsada" /> 🚛 Autopropulsada</label>
                    <label class="machine-chip"><input type="checkbox" class="machine-check" value="avion" /> ✈️ Avión</label>
                </div>
                <input type="hidden" name="machineTypes" id="machineTypesHidden" />
            </div>

            <div class="form-section">
                <h4 class="form-section-title">📍 Ubicación Principal</h4>
                <p style="color: #64748b; font-size: 0.85rem; margin-bottom: 0.75rem;">
                    Hacé click en el mapa o usá los botones para seleccionar tu ubicación.
                </p>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Nombre de la base *</label>
                        <input name="locationName" type="text" class="form-control"
                               placeholder="Base central" maxlength="150" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Dirección <span class="optional-tag">(opcional)</span></label>
                        <input name="locationAddress" type="text" class="form-control"
                               placeholder="Ruta 9 km 435" maxlength="300" />
                    </div>
                </div>

                <!-- Mapa interactivo -->
                <div class="map-wrapper">
                    <div id="locationMap" class="location-map"></div>
                    <div class="map-actions">
                        <button type="button" id="btnGeolocate" class="map-btn">
                            📍 Mi ubicación
                        </button>
                        <span id="mapHint" class="map-hint">Hacé click en el mapa para marcar tu ubicación</span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Latitud</label>
                        <input name="locationLat" id="locationLat" type="text" class="form-control coord-input"
                               placeholder="-32.6920" readonly />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Longitud</label>
                        <input name="locationLng" id="locationLng" type="text" class="form-control coord-input"
                               placeholder="-62.1026" readonly />
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a asp-controller="Home" asp-action="Index" class="btn-cancel">Cancelar</a>
                <button type="submit" class="btn-submit">Crear Perfil de Aplicador</button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <style>
        .back-link {
            display: inline-block;
            margin-bottom: 1.5rem;
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
        }
        .back-link:hover { text-decoration: underline; }

        .machine-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 6px 12px;
            border: 2px solid var(--border-color, #e2e8f0);
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: all 0.2s;
            user-select: none;
        }
        .machine-chip:has(input:checked) {
            border-color: #22c55e;
            background: #f0fdf4;
        }
        .machine-chip input { display: none; }

        /* Map styles */
        .map-wrapper {
            margin-bottom: 16px;
        }
        .location-map {
            height: 300px;
            border-radius: 10px;
            border: 2px solid #e2e8f0;
            cursor: crosshair;
            z-index: 0;
        }
        .map-actions {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 10px;
        }
        .map-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            background: #f0fdf4;
            border: 1px solid #86efac;
            border-radius: 8px;
            color: #166534;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .map-btn:hover {
            background: #dcfce7;
            border-color: #4ade80;
        }
        .map-btn:disabled {
            opacity: 0.5;
            cursor: wait;
        }
        .map-hint {
            color: #94a3b8;
            font-size: 0.82rem;
            font-style: italic;
        }
        .coord-input {
            background: #f8fafc;
            font-family: monospace;
            font-size: 0.9rem;
        }
    </style>
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        (function () {
            // ── Maquinaria: sync on every change ──
            var machineHidden = document.getElementById('machineTypesHidden');
            function syncMachines() {
                var checked = document.querySelectorAll('.machine-check:checked');
                machineHidden.value = Array.from(checked).map(function (c) { return c.value; }).join(',');
            }
            document.querySelectorAll('.machine-check').forEach(function (cb) {
                cb.addEventListener('change', syncMachines);
            });
            // Also sync on submit as safety net
            document.getElementById('applicatorForm').addEventListener('submit', syncMachines);

            // ── Mapa interactivo ──
            var latInput = document.getElementById('locationLat');
            var lngInput = document.getElementById('locationLng');
            var hint = document.getElementById('mapHint');
            var marker = null;

            // Centro default: Marcos Juárez, Córdoba
            var defaultLat = -32.69;
            var defaultLng = -62.10;

            var map = L.map('locationMap').setView([defaultLat, defaultLng], 8);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            function setLocation(lat, lng, zoom) {
                // Redondear a 4 decimales (~11m precisión)
                lat = parseFloat(lat.toFixed(4));
                lng = parseFloat(lng.toFixed(4));

                latInput.value = lat;
                lngInput.value = lng;

                if (marker) {
                    marker.setLatLng([lat, lng]);
                } else {
                    marker = L.marker([lat, lng], { draggable: true }).addTo(map);
                    marker.on('dragend', function (e) {
                        var pos = e.target.getLatLng();
                        setLocation(pos.lat, pos.lng);
                    });
                }

                if (zoom) {
                    map.setView([lat, lng], zoom);
                } else {
                    map.panTo([lat, lng]);
                }

                hint.textContent = 'Ubicación seleccionada. Podés arrastrar el marcador para ajustar.';
            }

            // Click en el mapa
            map.on('click', function (e) {
                setLocation(e.latlng.lat, e.latlng.lng, map.getZoom() < 12 ? 13 : undefined);
            });

            // Botón geolocalización
            document.getElementById('btnGeolocate').addEventListener('click', function () {
                var btn = this;
                if (!navigator.geolocation) {
                    hint.textContent = 'Tu navegador no soporta geolocalización.';
                    return;
                }

                btn.disabled = true;
                btn.textContent = '⏳ Buscando...';
                hint.textContent = 'Obteniendo tu ubicación...';

                navigator.geolocation.getCurrentPosition(
                    function (pos) {
                        setLocation(pos.coords.latitude, pos.coords.longitude, 14);
                        btn.disabled = false;
                        btn.textContent = '📍 Mi ubicación';
                    },
                    function (err) {
                        btn.disabled = false;
                        btn.textContent = '📍 Mi ubicación';
                        var msgs = {
                            1: 'Permiso de ubicación denegado.',
                            2: 'No se pudo determinar tu ubicación.',
                            3: 'Tiempo de espera agotado.'
                        };
                        hint.textContent = msgs[err.code] || 'Error al obtener ubicación.';
                    },
                    { enableHighAccuracy: true, timeout: 10000 }
                );
            });
        })();
    </script>
}
