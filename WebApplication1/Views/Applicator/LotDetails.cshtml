@{
    ViewData["Title"] = "Detalle del Lote";
}

<!-- Header sticky (same pattern as recipe detail) -->
<div class="detail-header">
    <div class="detail-header-content">
        <a asp-action="Lots" asp-controller="Applicator" class="back-button">← Mis Lotes</a>
        <h1 class="detail-title" id="lotTitle">Detalle del Lote</h1>
        <div class="detail-meta">
            <span id="lotCodeBadge" class="lot-code-badge"></span>
            <span id="lotAreaBadge" class="lot-area-badge"></span>
        </div>
    </div>
</div>

<div class="lot-detail-container">

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="lot-alert lot-alert-error"><span>⚠️</span> @errorMsg</div>
    }
    @if (TempData["Success"] is string successMsg)
    {
        <div class="lot-alert lot-alert-success"><span>✅</span> @successMsg</div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="lot-alert lot-alert-error"><span>⚠️</span> @ViewBag.Error</div>
    }

    <!-- Map + Info grid -->
    <div class="lot-grid">
        <div class="lot-map-wrapper">
            <div id="lotMap" class="lot-map"></div>
            <div class="lot-map-toolbar">
                <button type="button" id="btnEditPolygon" class="lot-btn-edit" onclick="startEditPolygon()">
                    ✏️ Editar Polígono
                </button>
                <button type="button" id="btnSavePolygon" class="lot-btn-save-polygon" style="display:none;" onclick="savePolygon()">
                    💾 Guardar Polígono
                </button>
                <button type="button" id="btnCancelEdit" class="lot-btn-cancel" style="display:none;" onclick="cancelEditPolygon()">
                    ✕ Cancelar
                </button>
                <span id="editStatus" class="lot-edit-status"></span>
            </div>
        </div>

        <div class="lot-sidebar">
            <!-- Info card -->
            <div class="lot-card">
                <h3 class="lot-card-title">📝 Información</h3>
                <form method="post" asp-action="EditLot" asp-controller="Applicator" id="editForm">
                    <input type="hidden" name="id" id="lotId" />
                    <input type="hidden" name="code" id="lotCode" />

                    <div class="lot-field">
                        <label for="name">Nombre</label>
                        <input type="text" id="name" name="name" maxlength="200" placeholder="Ej: Lote 5 - Campo Norte" />
                    </div>
                    <div class="lot-field">
                        <label for="locality">Localidad</label>
                        <input type="text" id="locality" name="locality" maxlength="150" placeholder="Marcos Juárez..." />
                    </div>
                    <div class="lot-field">
                        <label for="department">Departamento</label>
                        <input type="text" id="department" name="department" maxlength="150" placeholder="Marcos Juárez" />
                    </div>
                    <div class="lot-field-row">
                        <div class="lot-field">
                            <label>Superficie</label>
                            <div class="lot-field-value" id="lotArea">—</div>
                        </div>
                        <div class="lot-field">
                            <label>Creado</label>
                            <div class="lot-field-value" id="lotCreated">—</div>
                        </div>
                    </div>
                    <button type="submit" class="lot-btn-save">💾 Guardar Cambios</button>
                </form>
            </div>

            <!-- Stats card -->
            <div class="lot-card lot-stats-card">
                <div class="lot-stat">
                    <span class="lot-stat-value" id="statRecipes">0</span>
                    <span class="lot-stat-label">Recetas</span>
                </div>
                <div class="lot-stat">
                    <span class="lot-stat-value" id="statVertices">0</span>
                    <span class="lot-stat-label">Vértices</span>
                </div>
            </div>
        </div>
    </div>

    <!-- KPIs del lote -->
    <div id="kpisSection" style="display:none; margin-top:20px;">
        <div class="lot-kpis-grid">
            <div class="lot-kpi-card">
                <span class="lot-kpi-icon">📋</span>
                <span class="lot-kpi-value" id="kpiRecipes">—</span>
                <span class="lot-kpi-label">Recetas</span>
            </div>
            <div class="lot-kpi-card">
                <span class="lot-kpi-icon">✅</span>
                <span class="lot-kpi-value" id="kpiExecutions">—</span>
                <span class="lot-kpi-label">Aplicaciones completadas</span>
            </div>
            <div class="lot-kpi-card">
                <span class="lot-kpi-icon">📐</span>
                <span class="lot-kpi-value" id="kpiHa">—</span>
                <span class="lot-kpi-label">Ha tratadas</span>
            </div>
            <div class="lot-kpi-card">
                <span class="lot-kpi-icon">🌿</span>
                <span class="lot-kpi-value" id="kpiCrops">—</span>
                <span class="lot-kpi-label">Cultivos</span>
            </div>
            <div class="lot-kpi-card">
                <span class="lot-kpi-icon">⚗️</span>
                <span class="lot-kpi-value lot-kpi-small" id="kpiToxClass">—</span>
                <span class="lot-kpi-label">Clase tox. más usada</span>
            </div>
            <div class="lot-kpi-card">
                <span class="lot-kpi-icon">📅</span>
                <span class="lot-kpi-value lot-kpi-small" id="kpiFirstLast">—</span>
                <span class="lot-kpi-label">Período de actividad</span>
            </div>
        </div>
    </div>

    <!-- Historial de recetas -->
    <div class="lot-card" style="margin-top:20px;">
        <h3 class="lot-card-title">📋 Historial de Aplicaciones</h3>
        <div id="historialContent">
            <p style="color:#94a3b8; text-align:center; padding:2rem;">Cargando historial...</p>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
    <link rel="stylesheet" href="~/css/recipeDetail.css" asp-append-version="true" />
    <style>
        .lot-detail-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px 20px 40px;
        }

        /* ── Header badges ── */
        .lot-code-badge {
            background: rgba(255,255,255,0.2);
            color: #fff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            font-family: monospace;
        }

        .lot-area-badge {
            background: rgba(255,255,255,0.15);
            color: #fff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* ── Alerts ── */
        .lot-alert {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 18px;
            border-radius: 10px;
            margin-bottom: 16px;
            font-size: 0.9rem;
        }

        .lot-alert-error {
            background: #fee2e2;
            border: 1px solid #fca5a5;
            color: #991b1b;
        }

        .lot-alert-success {
            background: #d1fae5;
            border: 1px solid #6ee7b7;
            color: #065f46;
        }

        /* ── Grid ── */
        .lot-grid {
            display: grid;
            grid-template-columns: 1.6fr 1fr;
            gap: 20px;
        }

        /* ── Map ── */
        .lot-map-wrapper {
            background: #fff;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }

        .lot-map {
            height: 420px;
        }

        /* ── Map toolbar ── */
        .lot-map-toolbar {
            display: flex; align-items: center; gap: 8px;
            padding: 10px 14px; background: #f8fafc; border-top: 1px solid #e2e8f0;
        }
        .lot-btn-edit {
            padding: 7px 16px; background: #fff; border: 1px solid #d1d5db;
            border-radius: 8px; font-size: 0.85rem; font-weight: 600;
            color: #475569; cursor: pointer; transition: all 0.15s;
        }
        .lot-btn-edit:hover { border-color: #667eea; color: #667eea; }
        .lot-btn-save-polygon {
            padding: 7px 16px; background: #667eea; border: none;
            border-radius: 8px; font-size: 0.85rem; font-weight: 600;
            color: #fff; cursor: pointer; transition: all 0.15s;
        }
        .lot-btn-save-polygon:hover { background: #5a6fd6; }
        .lot-btn-cancel {
            padding: 7px 14px; background: #fee2e2; border: 1px solid #fca5a5;
            border-radius: 8px; font-size: 0.85rem; font-weight: 600;
            color: #991b1b; cursor: pointer;
        }
        .lot-btn-cancel:hover { background: #fecaca; }
        .lot-edit-status { font-size: 0.82rem; color: #64748b; margin-left: auto; }

        /* ── Sidebar cards ── */
        .lot-card {
            background: #fff;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            padding: 20px;
        }

        .lot-card-title {
            font-size: 1rem;
            font-weight: 700;
            color: #1e293b;
            margin: 0 0 16px;
            padding-bottom: 10px;
            border-bottom: 2px solid #667eea;
        }

        /* ── Form ── */
        .lot-field {
            margin-bottom: 12px;
        }

            .lot-field label {
                display: block;
                font-size: 0.8rem;
                font-weight: 600;
                color: #475569;
                margin-bottom: 4px;
                text-transform: uppercase;
                letter-spacing: 0.03em;
            }

            .lot-field input {
                width: 100%;
                padding: 9px 12px;
                border: 1px solid #d1d5db;
                border-radius: 8px;
                font-size: 0.9rem;
                font-family: inherit;
                box-sizing: border-box;
            }

                .lot-field input:focus {
                    border-color: #667eea;
                    outline: none;
                    box-shadow: 0 0 0 3px rgba(102,126,234,0.15);
                }

        .lot-field-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .lot-field-value {
            font-size: 0.95rem;
            color: #1e293b;
            font-weight: 600;
            padding: 8px 0;
        }

        .lot-btn-save {
            width: 100%;
            padding: 10px;
            border: none;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.95rem;
            margin-top: 8px;
            transition: all 0.2s;
        }

            .lot-btn-save:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 14px rgba(102,126,234,0.4);
            }

        /* ── Stats card ── */
        .lot-stats-card {
            display: flex;
            gap: 0;
            margin-top: 16px;
            padding: 0;
            overflow: hidden;
        }

        .lot-stat {
            flex: 1;
            text-align: center;
            padding: 16px 12px;
            border-right: 1px solid #e2e8f0;
        }

            .lot-stat:last-child {
                border-right: none;
            }

        .lot-stat-value {
            display: block;
            font-size: 1.5rem;
            font-weight: 800;
            color: #1e293b;
        }

        .lot-stat-label {
            display: block;
            font-size: 0.75rem;
            color: #64748b;
            text-transform: uppercase;
            margin-top: 2px;
        }

        /* ── Recipes table ── */
        .lot-recipes-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.88rem;
        }

            .lot-recipes-table th {
                text-align: left;
                padding: 10px 12px;
                background: #f8fafc;
                color: #475569;
                font-weight: 600;
                font-size: 0.78rem;
                text-transform: uppercase;
                letter-spacing: 0.03em;
                border-bottom: 2px solid #e2e8f0;
            }

            .lot-recipes-table td {
                padding: 10px 12px;
                border-bottom: 1px solid #f1f5f9;
                color: #334155;
            }

            .lot-recipes-table tr:hover td {
                background: #f8fafc;
            }

            .lot-recipes-table a {
                color: #667eea;
                text-decoration: none;
                font-weight: 600;
            }

                .lot-recipes-table a:hover {
                    text-decoration: underline;
                }

        .lot-status {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .lot-status-ABIERTA {
            background: #fef3c7;
            color: #92400e;
        }

        .lot-status-PENDIENTE {
            background: #dbeafe;
            color: #1e40af;
        }

        .lot-status-APROBADA {
            background: #d1fae5;
            color: #065f46;
        }

        .lot-status-RECHAZADA {
            background: #fee2e2;
            color: #991b1b;
        }

        .lot-status-OBSERVADA {
            background: #ffedd5;
            color: #9a3412;
        }

        .lot-status-CERRADA {
            background: #e2e8f0;
            color: #475569;
        }

        .lot-status-ANULADA {
            background: #fee2e2;
            color: #991b1b;
        }

        .lot-no-recipes {
            text-align: center;
            padding: 3rem;
            color: #94a3b8;
        }

        /* ── KPIs ── */
        .lot-kpis-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 12px;
        }

        .lot-kpi-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 16px 12px;
            text-align: center;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .lot-kpi-icon { font-size: 1.4rem; }

        .lot-kpi-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: #1e293b;
            line-height: 1.2;
        }

        .lot-kpi-small { font-size: 1rem; }

        .lot-kpi-label {
            font-size: 0.72rem;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }

        /* ── Historial cards ── */
        .hist-recipe-card {
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 14px;
        }

        .hist-recipe-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: #f8fafc;
            cursor: pointer;
            user-select: none;
        }

        .hist-recipe-header:hover { background: #f1f5f9; }

        .hist-recipe-code {
            font-family: monospace;
            font-size: 0.85rem;
            font-weight: 700;
            color: #667eea;
        }

        .hist-recipe-crop {
            font-size: 0.9rem;
            color: #1e293b;
            font-weight: 600;
            flex: 1;
        }

        .hist-recipe-date {
            font-size: 0.8rem;
            color: #64748b;
        }

        .hist-recipe-chevron {
            font-size: 0.8rem;
            color: #94a3b8;
            transition: transform 0.2s;
        }

        .hist-recipe-chevron.open { transform: rotate(180deg); }

        .hist-recipe-body {
            display: none;
            padding: 16px;
            border-top: 1px solid #e2e8f0;
        }

        .hist-recipe-body.open { display: block; }

        .hist-section-title {
            font-size: 0.78rem;
            font-weight: 700;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin: 0 0 8px;
        }

        .hist-section-title:not(:first-child) { margin-top: 16px; }

        .hist-meta-row {
            display: flex;
            gap: 24px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .hist-meta-item {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .hist-meta-label {
            font-size: 0.72rem;
            color: #94a3b8;
            text-transform: uppercase;
        }

        .hist-meta-value {
            font-size: 0.88rem;
            color: #1e293b;
            font-weight: 600;
        }

        .hist-products-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .hist-product-chip {
            display: flex;
            align-items: center;
            gap: 6px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            padding: 4px 10px;
            font-size: 0.8rem;
        }

        .hist-tox-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .hist-tox-Ia  { background: #7c3aed; }
        .hist-tox-Ib  { background: #dc2626; }
        .hist-tox-II  { background: #ea580c; }
        .hist-tox-III { background: #2563eb; }
        .hist-tox-IV  { background: #16a34a; }
        .hist-tox-    { background: #94a3b8; }

        .hist-exec-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            background: #f8fafc;
            border-radius: 8px;
            margin-bottom: 6px;
            font-size: 0.83rem;
        }

        .hist-exec-status {
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .hist-exec-COMPLETADA { background: #d1fae5; color: #065f46; }
        .hist-exec-EN_CURSO   { background: #dbeafe; color: #1e40af; }
        .hist-exec-PAUSADA    { background: #ffedd5; color: #9a3412; }
        .hist-exec-CANCELADA  { background: #fee2e2; color: #991b1b; }
        .hist-exec-PENDIENTE  { background: #f1f5f9; color: #475569; }
        .hist-exec-ACEPTADA   { background: #ede9fe; color: #5b21b6; }
        .hist-exec-EN_CAMINO  { background: #fef3c7; color: #92400e; }

        .hist-no-exec {
            font-size: 0.83rem;
            color: #94a3b8;
            font-style: italic;
        }

        @@media (max-width: 900px) {
            .lot-kpis-grid { grid-template-columns: repeat(3, 1fr); }
        }

        @@media (max-width: 768px) {
            .lot-grid { grid-template-columns: 1fr; }
            .lot-map { height: 300px; }
            .lot-kpis-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
    <script>
    var map, polygon, drawnItems, drawControl, originalCoords;
    var isEditing = false;
    var lotId;

    var statusLabels = {
        'ABIERTA': 'Abierta', 'PENDIENTE': 'Pendiente', 'APROBADA': 'Aprobada',
        'RECHAZADA': 'Rechazada', 'OBSERVADA': 'Observada',
        'CERRADA': 'Cerrada', 'ANULADA': 'Anulada',
        'COMPLETADA_MANUAL': 'Completada', 'CERRADA_MANUAL': 'Cerrada manual',
        'COMPLETADA_ADMIN': 'Completada admin'
    };

    // Datos del servidor
    var lot = @Html.Raw(ViewBag.LotJson ?? "null");
    var _historyRaw = @Html.Raw(ViewBag.HistoryJson ?? "null");
    var history = (_historyRaw && typeof _historyRaw === 'object') ? _historyRaw : null;

    (function() {
        if (!lot) return;

        lotId = lot.id;

        // Header
        document.getElementById('lotTitle').textContent = lot.name || ('Lote ' + lot.code);
        document.getElementById('lotCodeBadge').textContent = lot.code;
        document.getElementById('lotAreaBadge').textContent = lot.areaHa ? ('📐 ' + lot.areaHa.toFixed(1) + ' ha') : '';

        // Form
        document.getElementById('lotId').value = lot.id;
        document.getElementById('lotCode').value = lot.code;
        document.getElementById('name').value = lot.name || '';
        document.getElementById('locality').value = lot.locality || '';
        document.getElementById('department').value = lot.department || '';
        document.getElementById('lotArea').textContent = lot.areaHa ? lot.areaHa.toFixed(1) + ' ha' : 'N/D';
        document.getElementById('lotCreated').textContent = lot.createdAt
            ? new Date(lot.createdAt).toLocaleDateString('es-AR') : 'N/D';

        // Stats (del historial si está disponible, sino de lot.recipes)
        var recipes = lot.recipes || [];
        document.getElementById('statRecipes').textContent = (history && history.kpis) ? history.kpis.totalRecipes : recipes.length;
        document.getElementById('statVertices').textContent = (lot.vertices || []).length;

        // Map
        if (lot.vertices && lot.vertices.length >= 3) {
            map = L.map('lotMap').setView([lot.centroidLat || -32.69, lot.centroidLng || -62.10], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            var coords = lot.vertices.map(function(v) { return [v.latitude, v.longitude]; });
            originalCoords = JSON.parse(JSON.stringify(coords));

            drawnItems = new L.FeatureGroup();
            map.addLayer(drawnItems);

            polygon = L.polygon(coords, {
                color: '#667eea', weight: 3, fillColor: '#667eea', fillOpacity: 0.15
            });
            drawnItems.addLayer(polygon);
            map.fitBounds(polygon.getBounds(), { padding: [40, 40] });
        }

        // Renderizar historial o tabla simple de fallback
        if (history && history.kpis) {
            renderKpis(history.kpis);
            renderHistorial(history.recipes);
        } else {
            renderSimpleRecipes(recipes);
        }
    })();

    // ══════════════════════════════
    // KPIs
    // ══════════════════════════════

    function renderKpis(kpis) {
        document.getElementById('kpisSection').style.display = '';
        document.getElementById('kpiRecipes').textContent = kpis.totalRecipes || 0;
        document.getElementById('kpiExecutions').textContent = kpis.completedExecutions || 0;
        document.getElementById('kpiHa').textContent = kpis.totalHaTreated ? kpis.totalHaTreated.toFixed(1) + ' ha' : '—';
        document.getElementById('kpiCrops').textContent = (kpis.crops && kpis.crops.length > 0) ? kpis.crops.join(', ') : '—';
        document.getElementById('kpiToxClass').textContent = kpis.mostUsedToxClass || '—';

        if (kpis.firstApplicationDate && kpis.lastApplicationDate) {
            var first = new Date(kpis.firstApplicationDate).toLocaleDateString('es-AR', {month:'short', year:'numeric'});
            var last  = new Date(kpis.lastApplicationDate).toLocaleDateString('es-AR', {month:'short', year:'numeric'});
            document.getElementById('kpiFirstLast').textContent = first === last ? first : first + ' — ' + last;
        }
    }

    // ══════════════════════════════
    // HISTORIAL
    // ══════════════════════════════

    var execStatusLabels = {
        'COMPLETADA': 'Completada', 'EN_CURSO': 'En curso', 'PAUSADA': 'Pausada',
        'CANCELADA': 'Cancelada', 'PENDIENTE': 'Pendiente',
        'ACEPTADA': 'Aceptada', 'EN_CAMINO': 'En camino'
    };

    var riskColors = { 'ALTO': '#dc2626', 'MEDIO': '#f59e0b', 'BAJO': '#16a34a' };

    function toxDotClass(cls) {
        if (!cls) return 'hist-tox-';
        var c = cls.trim().replace(/\s+/g, '');
        if (c === 'Ia') return 'hist-tox-Ia';
        if (c === 'Ib') return 'hist-tox-Ib';
        if (c === 'II') return 'hist-tox-II';
        if (c === 'III') return 'hist-tox-III';
        if (c === 'IV') return 'hist-tox-IV';
        return 'hist-tox-';
    }

    function renderHistorial(recipes) {
        var container = document.getElementById('historialContent');
        if (!recipes || recipes.length === 0) {
            container.innerHTML = '<div style="text-align:center;padding:3rem;color:#94a3b8;">🌾 No hay recetas asociadas a este lote.</div>';
            return;
        }

        var html = '';
        recipes.forEach(function(r, idx) {
            var st = (r.status || '').toUpperCase();
            var stLabel = statusLabels[st] || st;
            var stClass = getStatusClass(st);
            var dateStr = r.issueDate ? new Date(r.issueDate).toLocaleDateString('es-AR') : '—';
            var infBadge = r.isInformal ? '<span style="background:#fef9c3;color:#713f12;font-size:0.7rem;padding:2px 7px;border-radius:10px;margin-left:6px;">Informal</span>' : '';
            var riskBadge = r.riskLevel ? '<span style="background:' + (riskColors[r.riskLevel] || '#94a3b8') + '20;color:' + (riskColors[r.riskLevel] || '#64748b') + ';font-size:0.72rem;padding:2px 8px;border-radius:10px;font-weight:700;">' + r.riskLevel + '</span>' : '';

            html += '<div class="hist-recipe-card">';

            // Header colapsable
            html += '<div class="hist-recipe-header" onclick="toggleCard(' + idx + ')">';
            html += '<span class="hist-recipe-code">' + (r.isInformal ? '📝' : '📄') + ' ' + r.publicCode + '</span>';
            html += '<span class="hist-recipe-crop">' + (r.crop || 'Sin cultivo') + infBadge + '</span>';
            if (riskBadge) html += riskBadge;
            html += '<span class="status-badge ' + stClass + '">' + stLabel + '</span>';
            html += '<span class="hist-recipe-date">' + dateStr + '</span>';
            html += '<span class="hist-recipe-chevron" id="chev-' + idx + '">▼</span>';
            html += '</div>';

            // Body
            html += '<div class="hist-recipe-body" id="body-' + idx + '">';

            // Meta
            html += '<p class="hist-section-title">Información</p>';
            html += '<div class="hist-meta-row">';
            if (r.municipalityName) {
                html += metaItem('Municipio', r.municipalityName);
            }
            if (r.surfaceHa) {
                html += metaItem('Superficie', r.surfaceHa.toFixed(1) + ' ha');
            }
            html += metaItem('Emisión', dateStr);
            html += '</div>';

            // Productos
            html += '<p class="hist-section-title">Productos aplicados</p>';
            if (r.products && r.products.length > 0) {
                html += '<div class="hist-products-list">';
                r.products.forEach(function(p) {
                    var doseStr = p.doseValue ? ' · ' + p.doseValue + (p.doseUnit ? ' ' + p.doseUnit : '') : '';
                    html += '<div class="hist-product-chip">';
                    html += '<span class="hist-tox-dot ' + toxDotClass(p.toxicologicalClass) + '"></span>';
                    html += '<span>' + p.productName + doseStr + '</span>';
                    html += '</div>';
                });
                html += '</div>';
            } else {
                html += '<span class="hist-no-exec">Sin productos registrados.</span>';
            }

            // Ejecuciones
            html += '<p class="hist-section-title">Ejecuciones de campo</p>';
            if (r.executions && r.executions.length > 0) {
                r.executions.forEach(function(e) {
                    var eSt = (e.status || '').toUpperCase();
                    var durStr = e.totalActiveMinutes ? ' · ' + Math.floor(e.totalActiveMinutes / 60) + 'h ' + (e.totalActiveMinutes % 60) + 'min' : '';
                    var originStr = e.origin === 'BOLSA' ? '🏪 Bolsa' : '👤 Directa';
                    var startStr = e.startedAt ? new Date(e.startedAt).toLocaleDateString('es-AR') : '—';

                    html += '<div class="hist-exec-row">';
                    html += '<span class="hist-exec-status hist-exec-' + eSt + '">' + (execStatusLabels[eSt] || eSt) + '</span>';
                    html += '<span style="flex:1;font-weight:600;">' + e.applicatorName + '</span>';
                    html += '<span style="color:#64748b;">' + originStr + '</span>';
                    html += '<span style="color:#64748b;">' + startStr + durStr + '</span>';
                    html += '</div>';
                });
            } else {
                html += '<span class="hist-no-exec">Sin ejecuciones registradas para esta receta.</span>';
            }

            html += '</div></div>'; // body + card
        });

        container.innerHTML = html;
    }

    function metaItem(label, value) {
        return '<div class="hist-meta-item"><span class="hist-meta-label">' + label + '</span><span class="hist-meta-value">' + value + '</span></div>';
    }

    function toggleCard(idx) {
        var body = document.getElementById('body-' + idx);
        var chev = document.getElementById('chev-' + idx);
        if (!body) return;
        var isOpen = body.classList.contains('open');
        body.classList.toggle('open', !isOpen);
        chev.classList.toggle('open', !isOpen);
    }

    function getStatusClass(st) {
        var map = {
            'ABIERTA':'status-draft','PENDIENTE':'status-pending','APROBADA':'status-approved',
            'RECHAZADA':'status-rejected','OBSERVADA':'status-warning',
            'CERRADA':'status-expired','ANULADA':'status-rejected',
            'COMPLETADA_MANUAL':'status-approved','CERRADA_MANUAL':'status-expired',
            'COMPLETADA_ADMIN':'status-approved'
        };
        return map[st] || 'status-draft';
    }

    // Fallback: tabla simple si no hay historial
    function renderSimpleRecipes(recipes) {
        var container = document.getElementById('historialContent');
        if (recipes.length === 0) {
            container.innerHTML = '<div style="text-align:center;padding:3rem;color:#94a3b8;">🌾 No hay recetas asociadas a este lote.</div>';
            return;
        }
        var html = '<table class="lot-recipes-table"><thead><tr>'
            + '<th>RFD</th><th>Fecha</th><th>Cultivo</th><th>Solicitante</th><th>Asesor</th><th>Estado</th>'
            + '</tr></thead><tbody>';
        recipes.forEach(function(r) {
            var st = (r.status || '').toUpperCase();
            var date = r.issueDate ? new Date(r.issueDate).toLocaleDateString('es-AR') : '—';
            html += '<tr>'
                + '<td><a href="/Applicator/Details?code=' + encodeURIComponent(r.publicCode) + '">#' + (r.rfdNumber || r.publicCode) + '</a></td>'
                + '<td>' + date + '</td><td>' + (r.crop || '—') + '</td>'
                + '<td>' + (r.requesterName || '—') + '</td><td>' + (r.advisorName || '—') + '</td>'
                + '<td><span class="lot-status lot-status-' + st + '">' + (statusLabels[st] || st) + '</span></td></tr>';
        });
        html += '</tbody></table>';
        container.innerHTML = html;
    }

    // ══════════════════════════════
    // POLYGON EDITING
    // ══════════════════════════════

    function startEditPolygon() {
        if (!polygon || !drawnItems) return;
        isEditing = true;
        document.getElementById('btnEditPolygon').style.display = 'none';
        document.getElementById('btnSavePolygon').style.display = '';
        document.getElementById('btnCancelEdit').style.display = '';
        document.getElementById('editStatus').textContent = 'Arrastrá los vértices para editar, o dibujá un polígono nuevo.';

        polygon.editing.enable();

        drawControl = new L.Control.Draw({
            draw: {
                polygon: { allowIntersection: false, shapeOptions: { color: '#f59e0b', weight: 3, fillOpacity: 0.2, fillColor: '#f59e0b' } },
                polyline: false, rectangle: false, circle: false, marker: false, circlemarker: false
            },
            edit: false
        });
        map.addControl(drawControl);

        map.on(L.Draw.Event.CREATED, function(e) {
            drawnItems.clearLayers();
            polygon = e.layer;
            polygon.setStyle({ color: '#667eea', weight: 3, fillColor: '#667eea', fillOpacity: 0.15 });
            drawnItems.addLayer(polygon);
            polygon.editing.enable();
            updateEditStatus();
        });
        polygon.on('edit', updateEditStatus);
    }

    function updateEditStatus() {
        if (!polygon) return;
        var latlngs = polygon.getLatLngs()[0];
        var area = calculateAreaHa(latlngs);
        document.getElementById('editStatus').textContent = '📐 ' + area.toFixed(1) + ' ha · ' + latlngs.length + ' vértices';
    }

    function cancelEditPolygon() {
        if (polygon && polygon.editing) polygon.editing.disable();
        drawnItems.clearLayers();
        polygon = L.polygon(originalCoords, { color: '#667eea', weight: 3, fillColor: '#667eea', fillOpacity: 0.15 });
        drawnItems.addLayer(polygon);
        if (drawControl) { map.removeControl(drawControl); drawControl = null; }
        map.off(L.Draw.Event.CREATED);
        isEditing = false;
        document.getElementById('btnEditPolygon').style.display = '';
        document.getElementById('btnSavePolygon').style.display = 'none';
        document.getElementById('btnCancelEdit').style.display = 'none';
        document.getElementById('editStatus').textContent = '';
        document.getElementById('editStatus').style.color = '';
    }

    async function savePolygon() {
        if (!polygon) return;
        if (polygon.editing) polygon.editing.disable();
        var latlngs = polygon.getLatLngs()[0];
        if (latlngs.length < 3) { alert('El polígono debe tener al menos 3 vértices.'); polygon.editing.enable(); return; }

        var vertices = latlngs.map(function(ll) {
            return { latitude: Math.round(ll.lat * 10000000) / 10000000, longitude: Math.round(ll.lng * 10000000) / 10000000 };
        });

        document.getElementById('editStatus').textContent = '⏳ Guardando...';
        document.getElementById('btnSavePolygon').disabled = true;

        try {
            var resp = await fetch('/Applicator/UpdateLotPolygon', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ lotId: lotId, vertices: vertices })
            });
            var data = await resp.json();

            if (data.success) {
                originalCoords = latlngs.map(function(ll) { return [ll.lat, ll.lng]; });
                document.getElementById('lotArea').textContent = data.areaHa ? data.areaHa.toFixed(1) + ' ha' : 'N/D';
                document.getElementById('lotAreaBadge').textContent = data.areaHa ? ('📐 ' + data.areaHa.toFixed(1) + ' ha') : '';
                document.getElementById('statVertices').textContent = data.verticesCount || latlngs.length;
                document.getElementById('editStatus').textContent = '✅ Polígono guardado';
                document.getElementById('editStatus').style.color = '#059669';
                if (drawControl) { map.removeControl(drawControl); drawControl = null; }
                map.off(L.Draw.Event.CREATED);
                isEditing = false;
                setTimeout(function() {
                    document.getElementById('btnEditPolygon').style.display = '';
                    document.getElementById('btnSavePolygon').style.display = 'none';
                    document.getElementById('btnCancelEdit').style.display = 'none';
                    document.getElementById('editStatus').textContent = '';
                    document.getElementById('editStatus').style.color = '';
                }, 2000);
            } else {
                document.getElementById('editStatus').textContent = '❌ ' + (data.error || 'Error al guardar');
                document.getElementById('editStatus').style.color = '#dc2626';
                polygon.editing.enable();
            }
        } catch (e) {
            document.getElementById('editStatus').textContent = '❌ Error de conexión';
            document.getElementById('editStatus').style.color = '#dc2626';
            polygon.editing.enable();
        }
        document.getElementById('btnSavePolygon').disabled = false;
    }

    function calculateAreaHa(latlngs) {
        if (latlngs.length < 3) return 0;
        var R = 6371000, toRad = Math.PI / 180, area = 0;
        for (var i = 0; i < latlngs.length; i++) {
            var j = (i + 1) % latlngs.length;
            area += (latlngs[j].lng - latlngs[i].lng) * toRad * (2 + Math.sin(latlngs[i].lat * toRad) + Math.sin(latlngs[j].lat * toRad));
        }
        return Math.abs(area * R * R / 2) / 10000;
    }
    </script>
}
