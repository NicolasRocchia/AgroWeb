@{
    ViewData["Title"] = "Detalle del Lote";
}

<div class="recipes-header">
    <div class="recipes-header-content">
        <h1 class="recipes-title">
            <span class="recipes-title-icon">🗺️</span>
            <span id="lotTitle">Detalle del Lote</span>
        </h1>
        <p class="recipes-subtitle">Información y recetas asociadas a este lote</p>
    </div>
</div>

<div style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert-error">
            <span class="alert-icon">⚠️</span>
            <div><strong>Error:</strong> @errorMsg</div>
        </div>
    }

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert-success">
            <span class="alert-icon">✅</span>
            <div>@successMsg</div>
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert-error">
            <span class="alert-icon">⚠️</span>
            <div><strong>Error:</strong> @ViewBag.Error</div>
        </div>
    }

    <!-- Map + Info -->
    <div class="lot-detail-grid">
        <div class="lot-map-container">
            <div id="lotMap" class="lot-detail-map"></div>
        </div>

        <div class="lot-info-panel">
            <div class="lot-info-section">
                <h3 class="section-title">📝 Información del Lote</h3>

                <form method="post" asp-action="EditLot" asp-controller="Applicator" id="editForm">
                    <input type="hidden" name="id" id="lotId" />

                    <div class="form-group">
                        <label for="name">Nombre</label>
                        <input type="text" id="name" name="name" maxlength="200" placeholder="Ej: Lote 5 - Campo Norte" />
                    </div>

                    <div class="form-group">
                        <label for="locality">Localidad</label>
                        <input type="text" id="locality" name="locality" maxlength="150" placeholder="Marcos Juárez..." />
                    </div>

                    <div class="form-group">
                        <label for="department">Departamento</label>
                        <input type="text" id="department" name="department" maxlength="150" placeholder="Marcos Juárez" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Superficie</label>
                            <div class="form-value" id="lotArea">-</div>
                        </div>
                        <div class="form-group">
                            <label>Creado</label>
                            <div class="form-value" id="lotCreated">-</div>
                        </div>
                    </div>

                    <button type="submit" class="btn-save">💾 Guardar Cambios</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Recipes History -->
    <div class="lot-recipes-section">
        <h3 class="section-title">📋 Recetas Asociadas</h3>

        <div id="recipesTable" class="recipes-table-container">
            <p style="color:#a0aec0; text-align:center; padding:2rem;">Cargando...</p>
        </div>
    </div>

    <div class="lot-actions">
        <a asp-action="Lots" asp-controller="Applicator" class="btn-back">← Volver a Mis Lotes</a>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        .lot-detail-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 1.5rem;
            margin-top: 1.5rem;
        }

        .lot-detail-map {
            height: 400px;
            border-radius: 12px;
            border: 2px solid #e2e8f0;
            z-index: 0;
        }

        .lot-info-panel {
            background: white;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            padding: 1.5rem;
        }

        .section-title {
            font-size: 1.05rem;
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #667eea;
        }

        .form-group {
            margin-bottom: 0.75rem;
        }

        .form-group label {
            display: block;
            font-weight: 500;
            margin-bottom: 0.25rem;
            font-size: 0.85rem;
            color: #4a5568;
        }

        .form-group input {
            width: 100%;
            padding: 0.5rem 0.7rem;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 0.9rem;
            box-sizing: border-box;
        }

        .form-group input:focus {
            border-color: #667eea;
            outline: none;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.15);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }

        .form-value {
            font-size: 0.9rem;
            color: #2d3748;
            font-weight: 500;
            padding: 0.5rem 0;
        }

        .btn-save {
            width: 100%;
            padding: 0.65rem;
            border: none;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.95rem;
            margin-top: 0.5rem;
            transition: all 0.2s;
        }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(102,126,234,0.4);
        }

        /* Recipes table */
        .lot-recipes-section {
            background: white;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            padding: 1.5rem;
            margin-top: 1.5rem;
        }

        .recipes-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }

        .recipes-table th {
            text-align: left;
            padding: 0.6rem 0.8rem;
            background: #f7fafc;
            color: #4a5568;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            border-bottom: 2px solid #e2e8f0;
        }

        .recipes-table td {
            padding: 0.6rem 0.8rem;
            border-bottom: 1px solid #edf2f7;
            color: #2d3748;
        }

        .recipes-table tr:hover td {
            background: #f7fafc;
        }

        .recipes-table a {
            color: #667eea;
            text-decoration: none;
            font-weight: 500;
        }

        .recipes-table a:hover {
            text-decoration: underline;
        }

        .status-badge {
            display: inline-block;
            padding: 0.15rem 0.5rem;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .status-ABIERTA   { background: #fefcbf; color: #975a16; }
        .status-PENDIENTE  { background: #bee3f8; color: #2a69ac; }
        .status-APROBADA   { background: #c6f6d5; color: #276749; }
        .status-RECHAZADA  { background: #fed7d7; color: #c53030; }
        .status-OBSERVADA  { background: #feebc8; color: #9c4221; }
        .status-CERRADA    { background: #e2e8f0; color: #4a5568; }
        .status-ANULADA    { background: #fed7d7; color: #c53030; }

        .no-recipes {
            text-align: center;
            padding: 2rem;
            color: #a0aec0;
        }

        .lot-actions {
            margin: 1.5rem 0 2rem;
        }

        .btn-back {
            display: inline-block;
            padding: 0.6rem 1.2rem;
            border: 1px solid #d1d5db;
            background: white;
            color: #4a5568;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-back:hover {
            background: #f7fafc;
            border-color: #667eea;
            color: #667eea;
        }

        .alert-error {
            display: flex; align-items: center; gap: 0.75rem;
            background: #fed7d7; border: 1px solid #e53e3e; color: #c53030;
            padding: 1rem; border-radius: 10px; margin-top: 1rem;
        }

        .alert-success {
            display: flex; align-items: center; gap: 0.75rem;
            background: #c6f6d5; border: 1px solid #38a169; color: #276749;
            padding: 1rem; border-radius: 10px; margin-top: 1rem;
        }

        @@media (max-width: 768px) {
            .lot-detail-grid {
                grid-template-columns: 1fr;
            }

            .lot-detail-map {
                height: 300px;
            }
        }
    </style>
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const lot = @Html.Raw(ViewBag.LotJson ?? "null");

        document.addEventListener('DOMContentLoaded', function () {
            if (!lot) return;

            // Title
            document.getElementById('lotTitle').textContent = lot.name || ('Lote #' + lot.id);

            // Form fields
            document.getElementById('lotId').value = lot.id;
            document.getElementById('name').value = lot.name || '';
            document.getElementById('locality').value = lot.locality || '';
            document.getElementById('department').value = lot.department || '';
            document.getElementById('lotArea').textContent = lot.areaHa ? lot.areaHa.toFixed(1) + ' ha' : 'N/D';
            document.getElementById('lotCreated').textContent = lot.createdAt
                ? new Date(lot.createdAt).toLocaleDateString('es-AR')
                : 'N/D';

            // Map
            if (lot.vertices && lot.vertices.length >= 3) {
                var map = L.map('lotMap').setView([lot.centroidLat || -32.69, lot.centroidLng || -62.10], 14);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap'
                }).addTo(map);

                var coords = lot.vertices.map(v => [v.latitude, v.longitude]);
                var polygon = L.polygon(coords, {
                    color: '#667eea', weight: 2,
                    fillColor: '#667eea', fillOpacity: 0.2
                }).addTo(map);

                map.fitBounds(polygon.getBounds(), { padding: [40, 40] });
            }

            // Recipes table
            var recipesDiv = document.getElementById('recipesTable');
            var recipes = lot.recipes || [];

            if (recipes.length === 0) {
                recipesDiv.innerHTML = '<div class="no-recipes">🌾 No hay recetas asociadas a este lote.</div>';
                return;
            }

            var statusLabels = {
                'ABIERTA': 'Abierta', 'PENDIENTE': 'Pendiente',
                'APROBADA': 'Aprobada', 'RECHAZADA': 'Rechazada',
                'OBSERVADA': 'Observada', 'CERRADA': 'Cerrada', 'ANULADA': 'Anulada'
            };

            var html = '<table class="recipes-table"><thead><tr>'
                + '<th>RFD</th><th>Fecha</th><th>Cultivo</th>'
                + '<th>Solicitante</th><th>Asesor</th><th>Estado</th>'
                + '</tr></thead><tbody>';

            recipes.forEach(function (r) {
                var st = (r.status || '').toUpperCase();
                var date = r.issueDate ? new Date(r.issueDate).toLocaleDateString('es-AR') : '-';
                html += '<tr>'
                    + '<td><a href="/Applicator/Details?code=' + encodeURIComponent(r.publicCode) + '">#' + (r.rfdNumber || r.publicCode) + '</a></td>'
                    + '<td>' + date + '</td>'
                    + '<td>' + (r.crop || '-') + '</td>'
                    + '<td>' + (r.requesterName || '-') + '</td>'
                    + '<td>' + (r.advisorName || '-') + '</td>'
                    + '<td><span class="status-badge status-' + st + '">' + (statusLabels[st] || st) + '</span></td>'
                    + '</tr>';
            });

            html += '</tbody></table>';
            recipesDiv.innerHTML = html;
        });
    </script>
}
