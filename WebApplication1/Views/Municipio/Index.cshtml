@model WebApplication1.Models.Recipes.RecipesIndexViewModel
@{
    ViewData["Title"] = "Recetas Asignadas";
}

<!-- Header Section -->
<div class="recipes-header">
    <div class="recipes-header-content">
        <h1 class="recipes-title">
            <span class="recipes-title-icon">📋</span>
            Recetas Asignadas
        </h1>
        <p class="recipes-subtitle">Recetas fitosanitarias asignadas a tu municipio</p>
    </div>
</div>

<div style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">

    <!-- Error / Success Alerts -->
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert-error">
            <span class="alert-icon">⚠️</span>
            <div><strong>Error:</strong> @errorMsg</div>
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert-error">
            <span class="alert-icon">⚠️</span>
            <div><strong>Error:</strong> @ViewBag.Error</div>
        </div>
    }

    <!-- Filters Section -->
    <div class="filters-container">
        <h2 class="filters-title">
            <span>🔍</span> Filtros de Búsqueda
        </h2>

        <form method="get" class="filters-form">
             <div class="filter-group">
            <label class="filter-label">Estado</label>
                <select name="status" class="filter-input" id="filterStatus">
                    <option value="">Todos</option>
                    <option value="PENDIENTE">⏳ Pendiente</option>
                    <option value="OBSERVADA">👁️ Observada</option>
                    <option value="APROBADA">✅ Aprobada</option>
                    <option value="RECHAZADA">❌ Rechazada</option>
                    <option value="ABIERTA">📝 Abierta</option>
                    <option value="CERRADA">🔒 Cerrada</option>
                    <option value="CERRADA_MANUAL">🔒 Cerrada Manual</option>
                    <option value="ANULADA">🚫 Anulada</option>
                </select>
        </div>

            <div class="filter-group">
                <label class="filter-label">Búsqueda General</label>
                <input name="searchText"
                       value="@Model.SearchText"
                       placeholder="Solicitante, asesor, cultivo..."
                       class="filter-input" />
            </div>

            <div class="filter-group">
                <label class="filter-label">Número RFD</label>
                <input name="rfdNumber"
                       value="@(Model.RfdNumber?.ToString() ?? "")"
                       placeholder="Ej: 12345"
                       type="number"
                       class="filter-input" />
            </div>

            <div class="filter-group">
                <button type="submit" class="filter-button">
                    🔎 Buscar
                </button>
            </div>
        </form>
    </div>

    <!-- Table Section -->
    <div class="table-container">
        @if (Model.Data.Items.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <h3>No hay recetas asignadas</h3>
                <p>Cuando los productores envíen recetas a este municipio, aparecerán aquí para su revisión.</p>
            </div>
        }
        else
        {
            <table class="recipes-table">
                <thead>
                    <tr>
                        <th>RFD</th>
                        <th>Estado</th>
                        <th>Riesgo</th>
                        <th>EIQ</th>
                        <th>Emisión</th>
                        <th>Vencimiento</th>
                        <th>Solicitante</th>
                        <th>Asesor</th>
                        <th>Cultivo</th>
                        <th class="text-right">Prod.</th>
                        <th class="text-right">Lotes</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Data.Items)
                    {
                        var statusClass = r.Status?.ToUpper() switch
                        {
                                                    "ABIERTA" => "status-draft",
                                                    "PENDIENTE" => "status-pending",
                                                    "APROBADA" => "status-approved",
                                                    "RECHAZADA" => "status-rejected",
                                                    "OBSERVADA" => "status-warning",
                                                    "CERRADA" => "status-expired",
                                                    "CERRADA_MANUAL" => "status-expired",
                                                    "ANULADA" => "status-rejected",
                            _ => "status-draft"
                        };

                        <tr>
                            <td><strong>@(r.RfdNumber.HasValue? r.RfdNumber.ToString() : "—")</strong></td>
                            <td>
                                <span class="status-badge @statusClass">
                                    @r.Status
                                </span>
                            </td>
                            <td>
                                @{
                                    var riskBadge = r.RiskLevel switch
                                    {
                                        "ALTO" => "<span style='display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:12px;font-size:.7rem;font-weight:700;background:#fef2f2;color:#991b1b;border:1px solid #fca5a5;' title='Riesgo alto'>🔴 Alto</span>",
                                        "MEDIO" => "<span style='display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:12px;font-size:.7rem;font-weight:700;background:#fffbeb;color:#92400e;border:1px solid #fcd34d;' title='Riesgo medio'>🟡 Medio</span>",
                                        "BAJO" => "<span style='display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:12px;font-size:.7rem;font-weight:700;background:#f0fdf4;color:#166534;border:1px solid #86efac;' title='Sin riesgo'>🟢 Bajo</span>",
                                        _ => "<span style='font-size:.7rem;color:#94a3b8;'>—</span>"
                                    };
                                }
                                @Html.Raw(riskBadge)
                            </td>
                            <td>
                                @{
                                    var eiqBadge = r.EiqLevel switch
                                    {
                                        "ALTO" => $"<span style='display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:12px;font-size:.7rem;font-weight:700;background:#fef2f2;color:#991b1b;border:1px solid #fca5a5;' title='EIQ: {r.EiqScore:F1}'>🔴 {r.EiqScore:F1}</span>",
                                        "MEDIO" => $"<span style='display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:12px;font-size:.7rem;font-weight:700;background:#fffbeb;color:#92400e;border:1px solid #fcd34d;' title='EIQ: {r.EiqScore:F1}'>🟡 {r.EiqScore:F1}</span>",
                                        "BAJO" => $"<span style='display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:12px;font-size:.7rem;font-weight:700;background:#f0fdf4;color:#166534;border:1px solid #86efac;' title='EIQ: {r.EiqScore:F1}'>🟢 {r.EiqScore:F1}</span>",
                                        _ => "<span style='font-size:.7rem;color:#94a3b8;'>—</span>"
                                    };
                                }
                                @Html.Raw(eiqBadge)
                            </td>
                            <td>@r.IssueDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (r.ExpirationDate.HasValue)
                                {
                                    var daysLeft = (r.ExpirationDate.Value - DateTime.UtcNow.Date).TotalDays;
                                    var expStyle = daysLeft < 0 ? "color:#991b1b; font-weight:700;"
                                    : daysLeft < 7 ? "color:#dc2626; font-weight:600;"
                                    : "";
                                    var expPrefix = daysLeft < 0 ? "⛔ " : daysLeft < 7 ? "⚠️ " : "";
                                    <span style="@expStyle">@expPrefix@r.ExpirationDate.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td>@r.RequesterName</td>
                            <td>@r.AdvisorName</td>
                            <td>@(r.Crop ?? "-")</td>
                            <td class="text-right"><strong>@r.ProductsCount</strong></td>
                            <td class="text-right"><strong>@r.LotsCount</strong></td>
                            <td>
                                <a asp-action="Details"
                                   asp-route-code="@r.PublicCode"
                                   class="btn-view"
                                   title="Ver detalles de la receta">
                                    <span class="btn-icon">👁️</span>
                                    Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Pagination -->
    @if (Model.Data.TotalPages > 1)
    {
        <div class="pagination-container">
            @if (Model.Data.HasPreviousPage)
            {
                <a asp-action="Index"
                   asp-route-page="@(Model.Data.Page - 1)"
                   asp-route-pageSize="@Model.Data.PageSize"
                   asp-route-status="@Model.Status"
                   asp-route-searchText="@Model.SearchText"
                   asp-route-rfdNumber="@Model.RfdNumber"
                   class="pagination-link">
                    ← Anterior
                </a>
            }

            <span class="pagination-info">
                Página <strong>@Model.Data.Page</strong> de <strong>@Model.Data.TotalPages</strong>
                — @Model.Data.TotalItems receta(s) en total
            </span>

            @if (Model.Data.HasNextPage)
            {
                <a asp-action="Index"
                   asp-route-page="@(Model.Data.Page + 1)"
                   asp-route-pageSize="@Model.Data.PageSize"
                   asp-route-status="@Model.Status"
                   asp-route-searchText="@Model.SearchText"
                   asp-route-rfdNumber="@Model.RfdNumber"
                   class="pagination-link">
                    Siguiente →
                </a>
            }
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/recipes.css" asp-append-version="true" />
    <style>
        .btn-upload-empty {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 1rem;
            padding: 0.75rem 1.5rem;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-upload-empty:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
                color: white;
            }
    </style>
}

<script>
    var statusSelect = document.getElementById('filterStatus');
    if (statusSelect) {
        var currentStatus = '@(Model.Status ?? "")';
        if (currentStatus) statusSelect.value = currentStatus;
    }
</script>
