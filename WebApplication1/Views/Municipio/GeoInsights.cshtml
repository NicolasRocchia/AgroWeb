@model WebApplication1.Models.Municipio.GeoInsightsViewModel
@{
    ViewData["Title"] = "Mapa Territorial";
}

<div class="geo-dashboard">

    <!-- ===== HEADER ===== -->
    <div class="geo-header">
        <div class="geo-header-content">
            <h1 class="geo-title">
                <span class="geo-title-icon">🗺️</span>
                Fiscalización Territorial
            </h1>
            <p class="geo-subtitle">Mapa de calor de aplicaciones fitosanitarias en tu jurisdicción</p>
        </div>
        <a asp-action="Index" class="geo-back-link">← Volver a Recetas</a>
    </div>

    <div class="geo-alert-error" id="geoErrorBar" style="display:none;">
        <span>⚠️</span>
        <div><strong id="geoErrorText"></strong></div>
    </div>

    <!-- ===== KPI CARDS ===== -->
    <div class="geo-kpi-grid" id="kpiGrid">
        <div class="geo-kpi-card geo-kpi-apps">
            <div class="geo-kpi-icon">📋</div>
            <div class="geo-kpi-value" id="kpiTotalApps">-</div>
            <div class="geo-kpi-label">Aplicaciones</div>
        </div>
        <div class="geo-kpi-card geo-kpi-hectares">
            <div class="geo-kpi-icon">🌾</div>
            <div class="geo-kpi-value" id="kpiHectares">-</div>
            <div class="geo-kpi-label">Hectáreas</div>
        </div>
        <div class="geo-kpi-card geo-kpi-products">
            <div class="geo-kpi-icon">🧪</div>
            <div class="geo-kpi-value" id="kpiProducts">-</div>
            <div class="geo-kpi-label">Productos</div>
        </div>
        <div class="geo-kpi-card geo-kpi-danger">
            <div class="geo-kpi-icon">☠️</div>
            <div class="geo-kpi-value" id="kpiHighTox">-</div>
            <div class="geo-kpi-label">Alta Toxicidad</div>
        </div>
        <div class="geo-kpi-card geo-kpi-advisors">
            <div class="geo-kpi-icon">👨‍🔬</div>
            <div class="geo-kpi-value" id="kpiAdvisors">-</div>
            <div class="geo-kpi-label">Asesores</div>
        </div>
        <div class="geo-kpi-card">
            <div class="geo-kpi-icon">🗺️</div>
            <div class="geo-kpi-value" id="kpiLots">-</div>
            <div class="geo-kpi-label">Lotes únicos</div>
        </div>
    </div>

    <!-- ===== FILTERS ===== -->
    <div class="geo-filters">
        <div class="geo-filters-header">
            <h3><span>🔍</span> Filtros</h3>
            <button type="button" class="geo-btn-clear" id="btnClearFilters">Limpiar</button>
        </div>
        <form method="get" class="geo-filters-form" id="filtersForm">
            <div class="geo-filter-group">
                <label>Fecha desde</label>
                <input type="date" name="dateFrom" id="filterDateFrom" value="@Context.Request.Query["dateFrom"]" />
            </div>
            <div class="geo-filter-group">
                <label>Fecha hasta</label>
                <input type="date" name="dateTo" id="filterDateTo" value="@Context.Request.Query["dateTo"]" />
            </div>
            <div class="geo-filter-group">
                <label>Cultivo</label>
                <select name="crop" id="filterCrop"><option value="">Todos</option></select>
            </div>
            <div class="geo-filter-group">
                <label>Clase Toxicológica</label>
                <select name="toxClass" id="filterToxClass"><option value="">Todas</option></select>
            </div>
            <div class="geo-filter-group">
                <label>Producto</label>
                <select name="productName" id="filterProduct"><option value="">Todos</option></select>
            </div>
            <div class="geo-filter-group">
                <label>Asesor</label>
                <select name="advisorName" id="filterAdvisor"><option value="">Todos</option></select>
            </div>
            <div class="geo-filter-group">
                <label>📍 Cercanía punto sensible</label>
                <select name="nearSensitivePointMeters" id="filterNearSP">
                    <option value="">Sin filtro</option>
                    <option value="200">A menos de 200m</option>
                    <option value="500">A menos de 500m</option>
                </select>
            </div>
            <div class="geo-filter-group geo-filter-actions">
                <button type="submit" class="geo-btn-filter">🔎 Filtrar</button>
            </div>
        </form>
    </div>

    <!-- ===== MAP ===== -->
    <div class="geo-map-wrapper">
        <div class="geo-map-container">
            <div id="geoMap" class="geo-map"></div>

            <div class="geo-controls-desktop">
                @await Html.PartialAsync("_GeoMapLegend")
                <div class="geo-map-toggles">
                    <label class="toggle-label">
                        <input type="checkbox" id="toggleHeatmap" checked /> Mapa de calor
                    </label>
                    <label class="toggle-label">
                        <input type="checkbox" id="togglePolygons" checked /> Polígonos
                    </label>
                    <label class="toggle-label">
                        <input type="checkbox" id="toggleSensitive" checked /> 📌 Pts. sensibles (municipal)
                    </label>
                    <label class="toggle-label">
                        <input type="checkbox" id="toggleSensitiveRecipe" /> 📍 Pts. sensibles (receta)
                    </label>
                    <label class="toggle-label">
                        <input type="checkbox" id="toggleExclusion" checked /> Zonas de exclusión
                    </label>
                </div>
            </div>

            <div class="geo-controls-mobile" id="mobileControls">
                <div class="geo-mobile-row">
                    <div class="geo-mobile-legend">
                        <span class="ml-chip"><span class="legend-color" style="background: rgba(0,180,0,0.3); border: 2px solid #00b400;"></span>IV</span>
                        <span class="ml-chip"><span class="legend-color" style="background: rgba(52,152,219,0.3); border: 2px solid #3498db;"></span>III</span>
                        <span class="ml-chip"><span class="legend-color" style="background: rgba(243,156,18,0.3); border: 2px solid #f39c12;"></span>II</span>
                        <span class="ml-chip"><span class="legend-color" style="background: rgba(231,76,60,0.3); border: 2px solid #e74c3c;"></span>Ib</span>
                        <span class="ml-chip"><span class="legend-color" style="background: rgba(142,68,173,0.3); border: 2px solid #8e44ad;"></span>Ia</span>
                        <span class="ml-chip"><span class="legend-dot" style="background: #e74c3c;"></span>Sensible</span>
                    </div>
                    <div class="geo-mobile-toggles">
                        <label class="mt-chip"><input type="checkbox" id="toggleHeatmapMobile" checked /> 🌡️</label>
                        <label class="mt-chip"><input type="checkbox" id="togglePolygonsMobile" checked /> 🔷</label>
                        <label class="mt-chip"><input type="checkbox" id="toggleSensitiveMobile" checked /> 📌</label>
                        <label class="mt-chip"><input type="checkbox" id="toggleSensitiveRecipeMobile" /> 📍</label>
                        <label class="mt-chip"><input type="checkbox" id="toggleExclusionMobile" checked /> 🚫</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @*
    ========================================================================
    PANEL DE ALERTAS (desactivado por ahora)
    Para activarlo:
    1. Descomentar este bloque HTML
    2. En GeoInsightsService.cs descomentar las secciones 3 y 4
    ========================================================================
    *@

    <!-- ===== ANALYTICS ===== -->
    <div class="geo-analytics">
        <div class="geo-chart-card">
            <h3>📈 Evolución temporal</h3>
            <div class="geo-chart"><canvas id="timelineChart"></canvas></div>
        </div>
        <div class="geo-chart-card">
            <h3>☠️ Distribución por toxicidad</h3>
            <div class="geo-chart"><canvas id="toxChart"></canvas></div>
        </div>
        <div class="geo-chart-card">
            <h3>🌱 Top cultivos</h3>
            <div class="geo-chart"><canvas id="cropChart"></canvas></div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/recipes.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="stylesheet" href="~/css/geoInsights.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script src="~/js/geoInsights.js" asp-append-version="true"></script>

    <script>
        window.addEventListener('load', () => {
            GeoInsights.init({
                geoData: @Html.Raw(Model.JsonData),
                geoDataUrlBase: null,
                detailUrlBase: '@Url.Action("Details", "Municipio")',
                serverError: @Html.Raw(ViewBag.Error != null
                                    ? System.Text.Json.JsonSerializer.Serialize(ViewBag.Error.ToString())
                                    : "null"),
            useAjaxFilters: false,
            heatGradient: { 0.2: '#2ecc71', 0.4: '#f1c40f', 0.6: '#e67e22', 0.8: '#e74c3c', 1.0: '#8e44ad' }
        });
        GeoInsights.loadExclusionZones();

            // Restore filter values from URL query params on page reload
            var params = new URLSearchParams(window.location.search);
            ['filterDateFrom:dateFrom', 'filterDateTo:dateTo', 'filterCrop:crop',
                'filterToxClass:toxClass', 'filterProduct:productName',
                'filterAdvisor:advisorName', 'filterNearSP:nearSensitivePointMeters'].forEach(function(pair) {
                    var parts = pair.split(':');
                    var el = document.getElementById(parts[0]);
                    var val = params.get(parts[1]);
                    if (el && val) el.value = val;
                });
        });
    </script>
}
