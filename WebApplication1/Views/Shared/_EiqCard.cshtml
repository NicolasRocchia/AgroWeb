@* _EiqCard.cshtml — Partial para mostrar EIQ de campo en detalle de receta *@
@model WebApplication1.Models.Recipes.RecipeDetailDto

@if (Model.EiqScore.HasValue)
{
    var levelColor = Model.EiqLevel switch
    {
        "ALTO" => ("🔴", "#991b1b", "#fef2f2", "#fca5a5"),
        "MEDIO" => ("🟡", "#92400e", "#fffbeb", "#fcd34d"),
        "BAJO" => ("🟢", "#166534", "#f0fdf4", "#86efac"),
        _ => ("⚪", "#64748b", "#f8fafc", "#cbd5e1")
    };

    <div class="detail-section">
        <h2 class="section-title"><span class="section-icon">🧪</span> Impacto Ambiental (EIQ)</h2>
        <div style="display:flex; gap:16px; flex-wrap:wrap; align-items:stretch;">
            @* Score principal *@
            <div style="flex:1; min-width:180px; padding:16px; border-radius:12px; background:@levelColor.Item3; border:1px solid @levelColor.Item4; text-align:center;">
                <div style="font-size:2rem; font-weight:800; color:@levelColor.Item2;">
                    @levelColor.Item1 @Model.EiqScore?.ToString("F1")
                </div>
                <div style="font-size:.85rem; color:@levelColor.Item2; font-weight:600; margin-top:4px;">
                    EIQ de Campo — @Model.EiqLevel
                </div>
                <div style="font-size:.75rem; color:#94a3b8; margin-top:4px;">
                    Cobertura: @(Model.EiqCoverage ?? "N/A") de los activos
                </div>
            </div>

            @* Desglose 3 componentes *@
            <div style="flex:2; min-width:250px; display:flex; gap:12px; flex-wrap:wrap;">
                <div style="flex:1; min-width:120px; padding:12px; border-radius:8px; background:#f8fafc; border:1px solid #e2e8f0;">
                    <div style="font-size:.7rem; text-transform:uppercase; letter-spacing:1px; color:#64748b; margin-bottom:4px;">👷 Trabajador</div>
                    <div style="font-size:1.3rem; font-weight:700; color:#1e293b;">@(Model.EiqFarmWorker?.ToString("F1") ?? "—")</div>
                </div>
                <div style="flex:1; min-width:120px; padding:12px; border-radius:8px; background:#f8fafc; border:1px solid #e2e8f0;">
                    <div style="font-size:.7rem; text-transform:uppercase; letter-spacing:1px; color:#64748b; margin-bottom:4px;">🏠 Consumidor</div>
                    <div style="font-size:1.3rem; font-weight:700; color:#1e293b;">@(Model.EiqConsumer?.ToString("F1") ?? "—")</div>
                </div>
                <div style="flex:1; min-width:120px; padding:12px; border-radius:8px; background:#f8fafc; border:1px solid #e2e8f0;">
                    <div style="font-size:.7rem; text-transform:uppercase; letter-spacing:1px; color:#64748b; margin-bottom:4px;">🌿 Ecológico</div>
                    <div style="font-size:1.3rem; font-weight:700; color:#1e293b;">@(Model.EiqEcological?.ToString("F1") ?? "—")</div>
                </div>
            </div>
        </div>
    </div>
}
