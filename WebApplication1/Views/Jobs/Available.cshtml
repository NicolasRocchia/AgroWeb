@{
    ViewData["Title"] = "Bolsa de Trabajo";
    var jobsJson = ViewBag.JobsJson as string ?? "[]";
}

<div class="page-container" style="max-width: 1000px; margin: 0 auto; padding: 0 20px 40px;">
    <a asp-controller="Home" asp-action="Index" class="back-link">← Inicio</a>
    <h1 class="page-title">📋 Bolsa de Trabajo</h1>
    <p style="color: #64748b; margin-bottom: 16px;">Trabajos disponibles ordenados por cercanía a tu ubicación.</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert-box alert-success-box"><span>✅</span> @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-box alert-error-box"><span>⚠️</span> @TempData["Error"]</div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert-box alert-error-box"><span>⚠️</span> @ViewBag.Error</div>
    }

    <!-- Filtros -->
    <div id="filtersPanel" class="filters-panel" style="display:none;">
        <div class="filters-row">
            <div class="filter-group">
                <label class="filter-label">🌱 Cultivo</label>
                <select id="filterCrop" class="filter-control" onchange="applyFilters()">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">💧 Tipo aplicación</label>
                <select id="filterAppType" class="filter-control" onchange="applyFilters()">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">📍 Distancia máx.</label>
                <select id="filterDistance" class="filter-control" onchange="applyFilters()">
                    <option value="">Sin límite</option>
                    <option value="10">10 km</option>
                    <option value="25">25 km</option>
                    <option value="50">50 km</option>
                    <option value="100">100 km</option>
                    <option value="200">200 km</option>
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">📋 Estado</label>
                <label class="filter-checkbox">
                    <input type="checkbox" id="filterHideApplied" onchange="applyFilters()" />
                    Ocultar ya postulados
                </label>
            </div>
        </div>
        <div id="filterResults" class="filter-results"></div>
    </div>

    <div id="jobsList"></div>
    <div id="emptyState" style="display:none; text-align:center; padding:60px 20px; color:#64748b;">
        <div style="font-size:3rem; margin-bottom:16px;">🔍</div>
        <h3>No hay trabajos disponibles</h3>
        <p>Cuando un productor publique un trabajo, aparecerá acá.</p>
    </div>
    <div id="noResults" style="display:none; text-align:center; padding:40px 20px; color:#94a3b8;">
        <div style="font-size:2rem; margin-bottom:12px;">🔍</div>
        <p>No hay trabajos que coincidan con los filtros.</p>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/jobs.css" asp-append-version="true" />
    <style>
        .filters-panel {
            background: white;
            border-radius: 12px;
            padding: 16px 20px;
            box-shadow: 0 2px 10px rgba(0,0,0,.06);
            margin-bottom: 20px;
        }

        .filters-row {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            align-items: flex-end;
        }

        .filter-group {
            flex: 1;
            min-width: 150px;
        }

        .filter-label {
            display: block;
            font-size: .78rem;
            color: #64748b;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .filter-control {
            width: 100%;
            padding: 8px 10px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: .85rem;
            color: #334155;
            background: #f8fafc;
        }

        .filter-checkbox {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: .85rem;
            color: #475569;
            cursor: pointer;
            padding: 8px 0;
        }

            .filter-checkbox input {
                cursor: pointer;
            }

        .filter-results {
            font-size: .82rem;
            color: #94a3b8;
            margin-top: 10px;
        }

        .job-card-applied {
            opacity: .6;
            border-left-color: #94a3b8 !important;
        }

        .applied-badge {
            display: inline-block;
            background: #dbeafe;
            color: #1e40af;
            padding: 2px 10px;
            border-radius: 12px;
            font-size: .72rem;
            font-weight: 600;
            margin-left: 6px;
            vertical-align: middle;
        }

        @@media (max-width: 768px) {
            .filters-row {
                flex-direction: column;
            }

            .filter-group {
                min-width: 100%;
            }
        }
    </style>
}

@section Scripts {
    <script>
        (function() {
            var allJobs = @Html.Raw(jobsJson);
            var container = document.getElementById('jobsList');
            var empty = document.getElementById('emptyState');
            var noResults = document.getElementById('noResults');
            var filtersPanel = document.getElementById('filtersPanel');
            var filterResults = document.getElementById('filterResults');

            if (!allJobs || allJobs.length === 0) {
                empty.style.display = 'block';
                return;
            }

            // Show filters
            filtersPanel.style.display = 'block';

            // Populate filter dropdowns from data
            var crops = new Set();
            var appTypes = new Set();
            allJobs.forEach(function(j) {
                if (j.crop) crops.add(j.crop);
                if (j.applicationType) appTypes.add(j.applicationType);
            });

            var cropSelect = document.getElementById('filterCrop');
            crops.forEach(function(c) {
                var opt = document.createElement('option');
                opt.value = c; opt.textContent = c;
                cropSelect.appendChild(opt);
            });

            var appTypeSelect = document.getElementById('filterAppType');
            appTypes.forEach(function(t) {
                var opt = document.createElement('option');
                opt.value = t; opt.textContent = t;
                appTypeSelect.appendChild(opt);
            });

            // Filter & render
            window.applyFilters = function() {
                var cropFilter = document.getElementById('filterCrop').value;
                var appTypeFilter = document.getElementById('filterAppType').value;
                var distFilter = document.getElementById('filterDistance').value;
                var hideApplied = document.getElementById('filterHideApplied').checked;

                var filtered = allJobs.filter(function(j) {
                    if (cropFilter && j.crop !== cropFilter) return false;
                    if (appTypeFilter && j.applicationType !== appTypeFilter) return false;
                    if (distFilter && j.distanceKm != null && j.distanceKm > parseFloat(distFilter)) return false;
                    if (hideApplied && j.alreadyApplied) return false;
                    return true;
                });

                renderJobs(filtered);

                if (filtered.length < allJobs.length) {
                    filterResults.textContent = 'Mostrando ' + filtered.length + ' de ' + allJobs.length + ' trabajos';
                } else {
                    filterResults.textContent = '';
                }
            };

            function renderJobs(jobs) {
                container.innerHTML = '';
                noResults.style.display = 'none';

                if (jobs.length === 0) {
                    noResults.style.display = 'block';
                    return;
                }

                jobs.forEach(function(j) {
                    var card = document.createElement('a');
                    card.href = '/Jobs/Detail/' + j.id;
                    card.className = 'job-card' + (j.alreadyApplied ? ' job-card-applied' : '');
                    card.innerHTML =
                        '<div class="job-card-left">' +
                        '<div class="job-title">' + j.title +
                        (j.alreadyApplied ? '<span class="applied-badge">✅ Postulado</span>' : '') +
                        '</div>' +
                        '<div class="job-meta">' +
                        (j.crop ? '<span>🌱 ' + j.crop + '</span>' : '') +
                        (j.applicationType ? '<span>💧 ' + j.applicationType + '</span>' : '') +
                        (j.surfaceHa ? '<span>📐 ' + j.surfaceHa + ' ha</span>' : '') +
                        (j.locality ? '<span>📍 ' + j.locality + '</span>' : '') +
                        '<span>📅 ' + new Date(j.createdAt).toLocaleDateString('es-AR') + '</span>' +
                        '<span>👤 ' + j.applicationCount + ' postulación' + (j.applicationCount !== 1 ? 'es' : '') + '</span>' +
                        '</div>' +
                        '</div>' +
                        '<div class="job-card-right">' +
                        (j.distanceKm != null
                            ? '<div class="job-distance">' + j.distanceKm + ' km</div><div class="job-distance-label">de distancia</div>'
                            : '<div class="job-distance" style="color:#94a3b8;">—</div>') +
                        '<div class="job-producer">por ' + j.producerName + '</div>' +
                        '</div>';
                    container.appendChild(card);
                });
            }

            // Initial render
            renderJobs(allJobs);
        })();
    </script>
}
