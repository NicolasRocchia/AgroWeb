@{
    ViewData["Title"] = "AGROCONNECT - Gestión de Recetas Fitosanitarias";
    var isAdmin = User.IsInRole("Admin");
    var isProductor = User.IsInRole("Productor");
    var isAplicador = User.IsInRole("Aplicador");
    var isOperario = User.IsInRole("Operario");
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    var userName = User?.Identity?.Name ?? "Usuario";
}

@* ======================================================
   ADMIN DASHBOARD
   ====================================================== *@
@if (isAdmin)
{
    <div class="hero-section hero-admin">
        <div class="hero-content">
            <div class="logo-container">
                <span class="logo-icon">⚙️</span>
                <h1 class="logo-text">Panel de Administración</h1>
            </div>
            <p class="hero-subtitle">Bienvenido, @userName</p>
            <p class="hero-description">
                Gestioná usuarios, recetas y configuraciones del sistema desde un solo lugar.
            </p>
        </div>
    </div>

    <div class="features-section">
        <div class="container">
            <h2 class="section-title">Herramientas de Administración</h2>

            <div class="features-grid">
                <div class="feature-card admin-card">
                    <div class="feature-icon">📋</div>
                    <h3>Recetas</h3>
                    <p>Visualizá y gestioná todas las recetas fitosanitarias del sistema. Filtrá por estado, solicitante, asesor o fecha.</p>
                    <a asp-controller="AdminRecipes" asp-action="Index" class="feature-btn">
                        Ver Recetas <span>→</span>
                    </a>
                </div>

                <div class="feature-card admin-card">
                    <div class="feature-icon">👥</div>
                    <h3>Usuarios</h3>
                    <p>Creá nuevos usuarios, asignales roles, bloqueá o desbloqueá cuentas. Control total del acceso al sistema.</p>
                    <a asp-controller="Admin" asp-action="Users" class="feature-btn">
                        Gestionar Usuarios <span>→</span>
                    </a>
                </div>

                <div class="feature-card admin-card">
                    <div class="feature-icon">📊</div>
                    <h3>Insights</h3>
                    <p>Estadísticas de recetas, productos más usados, tipos de aplicación y actividad del sistema.</p>
                    <a asp-controller="Admin" asp-action="Insights" class="feature-btn">
                        Ver Insights <span>→</span>
                    </a>
                </div>

                <div class="feature-card admin-card">
                    <div class="feature-icon">📚</div>
                    <h3>API Docs</h3>
                    <p>Documentación interactiva de la API REST. Probá endpoints directamente desde Swagger.</p>
                    <a href="/swagger" class="feature-btn" target="_blank">
                        Ver API <span>→</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
@* ======================================================
   PRODUCTOR + APLICADOR (ambos roles)
   ====================================================== *@
else if (isProductor && isAplicador)
{
    <div class="hero-section">
        <div class="hero-content">
            <div class="logo-container">
                <span class="logo-icon">🌾</span>
                <h1 class="logo-text">AGROCONNECT</h1>
            </div>
            <p class="hero-subtitle">Bienvenido, @userName</p>
            <p class="hero-description">
                Gestioná tus recetas y tus servicios de aplicación desde un solo lugar.
            </p>
        </div>
    </div>

    <div class="features-section">
        <div class="container">
            <h2 class="section-title">Mis Recetas</h2>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">📤</div>
                    <h3>Subir Receta</h3>
                    <p>Cargá un PDF de receta fitosanitaria. El sistema extrae automáticamente toda la información.</p>
                    <a asp-controller="Applicator" asp-action="Upload" class="feature-btn">
                        Subir Receta <span>→</span>
                    </a>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🔍</div>
                    <h3>Mis Recetas</h3>
                    <p>Consultá el historial de recetas que cargaste. Buscá por número RFD, fecha o cualquier criterio.</p>
                    <a asp-controller="Applicator" asp-action="Index" class="feature-btn">
                        Ver Mis Recetas <span>→</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="features-section">
        <div class="container">
            <h2 class="section-title">Servicios de Aplicación</h2>
            <div class="features-grid">
                <div class="feature-card aplicador-card">
                    <div class="feature-icon">📋</div>
                    <h3>Bolsa de Trabajo</h3>
                    <p>Explorá trabajos de aplicación disponibles cerca de tus ubicaciones. Ofertá y conseguí nuevos clientes.</p>
                    <a asp-controller="Jobs" asp-action="Available" class="feature-btn">
                        Ver Trabajos <span>→</span>
                    </a>
                </div>
                <div class="feature-card aplicador-card">
                    <div class="feature-icon">📌</div>
                    <h3>Mis Tareas</h3>
                    <p>Gestioná las tareas de aplicación que tenés asignadas.</p>
                    <a asp-controller="Jobs" asp-action="MyTasks" class="feature-btn">
                        Ver Mis Tareas <span>→</span>
                    </a>
                </div>
                <div class="feature-card aplicador-card">
                    <div class="feature-icon">🚜</div>
                    <h3>Mi Perfil de Aplicador</h3>
                    <p>Configurá tu perfil, maquinaria disponible y ubicaciones para aparecer en la bolsa de trabajo.</p>
                    <a asp-controller="Applicator" asp-action="MyProfile" class="feature-btn">
                        Ver Mi Perfil <span>→</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
@* ======================================================
   PRODUCTOR HOME
   ====================================================== *@
else if (isProductor)
{
    <div class="hero-section">
        <div class="hero-content">
            <div class="logo-container">
                <span class="logo-icon">🌾</span>
                <h1 class="logo-text">AGROCONNECT</h1>
            </div>
            <p class="hero-subtitle">Bienvenido, @userName</p>
            <p class="hero-description">
                Gestioná tus recetas fitosanitarias de forma digital, rápida y segura.
            </p>
        </div>
    </div>

    <div class="features-section">
        <div class="container">
            <h2 class="section-title">¿Qué querés hacer?</h2>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">📤</div>
                    <h3>Subir Receta</h3>
                    <p>Cargá un PDF de receta fitosanitaria. El sistema extrae automáticamente toda la información: productos, lotes, condiciones y más.</p>
                    <a asp-controller="Applicator" asp-action="Upload" class="feature-btn">
                        Subir Receta <span>→</span>
                    </a>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">📝</div>
                    <h3>Crear Receta de Registro</h3>
                    <p>Cargá una receta manualmente para registro interno. No requiere aprobación municipal.</p>
                    <a asp-controller="Applicator" asp-action="CreateManual" class="feature-btn">
                        Crear Receta <span>→</span>
                    </a>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">🔍</div>
                    <h3>Mis Recetas</h3>
                    <p>Consultá el historial de recetas que cargaste. Buscá por número RFD, fecha, solicitante o cualquier criterio.</p>
                    <a asp-controller="Applicator" asp-action="Index" class="feature-btn">
                        Ver Mis Recetas <span>→</span>
                    </a>
                </div>

                <div class="feature-card aplicador-card">
                    <div class="feature-icon">🚜</div>
                    <h3>Ofrecer Servicios de Aplicación</h3>
                    <p>¿Tenés maquinaria? Registrate como aplicador para ofertar tus servicios y conseguir clientes.</p>
                    <a asp-controller="Applicator" asp-action="BecomeApplicator" class="feature-btn">
                        Registrarme como Aplicador <span>→</span>
                    </a>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">📋</div>
                    <h3>Bolsa de Trabajo</h3>
                    <p>Publicá un trabajo para que aplicadores se postulen. Revisá postulaciones y elegí a quién contratar.</p>
                    <a asp-controller="Jobs" asp-action="MyJobs" class="feature-btn">
                        Mis Trabajos <span>→</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
@* ======================================================
   APLICADOR HOME
   ====================================================== *@
else if (isAplicador)
{
    <div class="hero-section hero-aplicador">
        <div class="hero-content">
            <div class="logo-container">
                <span class="logo-icon">🚜</span>
                <h1 class="logo-text">AGROCONNECT</h1>
            </div>
            <p class="hero-subtitle">Bienvenido, @userName</p>
            <p class="hero-description">
                Encontrá trabajos de aplicación, gestioná tus tareas y hacé crecer tu negocio.
            </p>
        </div>
    </div>

    <div class="features-section">
        <div class="container">
            <h2 class="section-title">¿Qué querés hacer?</h2>

            <div class="features-grid">
                <div class="feature-card aplicador-card">
                    <div class="feature-icon">📋</div>
                    <h3>Bolsa de Trabajo</h3>
                    <p>Explorá trabajos de aplicación disponibles cerca de tus ubicaciones. Filtrá por distancia, cultivo o tipo de aplicación y ofertá tu servicio.</p>
                    <a asp-controller="Jobs" asp-action="Available" class="feature-btn">
                        Ver Trabajos <span>→</span>
                    </a>
                </div>

                <div class="feature-card aplicador-card">
                    <div class="feature-icon">📌</div>
                    <h3>Mis Tareas</h3>
                    <p>Visualizá y gestioná las tareas de aplicación que tenés asignadas.</p>
                    <a asp-controller="Jobs" asp-action="MyTasks" class="feature-btn">
                        Ver Mis Tareas <span>→</span>
                    </a>
                </div>

                <div class="feature-card aplicador-card">
                    <div class="feature-icon">🚜</div>
                    <h3>Mi Perfil</h3>
                    <p>Consultá tu perfil de aplicador, tu maquinaria disponible y tus ubicaciones. Verificá el estado de tu cuenta.</p>
                    <a asp-controller="Applicator" asp-action="MyProfile" class="feature-btn">
                        Ver Mi Perfil <span>→</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
@* ======================================================
   OPERARIO DASHBOARD
   ====================================================== *@
else if (isOperario)
{
    <div class="hero-section" style="background: linear-gradient(135deg, #1e3a5f 0%, #2d5f8a 100%);">
        <div class="hero-content">
            <div class="logo-container">
                <span class="logo-icon">👷</span>
                <h1 class="logo-text">AGROCONNECT</h1>
            </div>
            <p class="hero-subtitle">Bienvenido, @userName</p>
            <p class="hero-description">
                Consultá tus ejecuciones asignadas y ejecutá los trabajos de campo.
            </p>
        </div>
    </div>

    <div class="features-section">
        <div class="container">
            <h2 class="section-title">¿Qué querés hacer?</h2>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">🚜</div>
                    <h3>Mis Ejecuciones</h3>
                    <p>Visualizá las ejecuciones asignadas por tu empresa. Aceptá, ejecutá el checklist e iniciá la aplicación.</p>
                    <a asp-controller="Executions" asp-action="MyOperatorExecutions" class="feature-btn">
                        Ver Ejecuciones <span>→</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
@* ======================================================
   LANDING PÚBLICA (no autenticado)
   ====================================================== *@
else
{
    <div class="hero-section">
        <div class="hero-content">
            <div class="logo-container">
                <span class="logo-icon">🌾</span>
                <h1 class="logo-text">AGROCONNECT</h1>
            </div>
            <p class="hero-subtitle">Sistema de Gestión de Recetas Fitosanitarias</p>
            <p class="hero-description">
                Plataforma integral para la carga, gestión y aprobación de recetas fitosanitarias.
                Conectando agricultores, asesores y municipios en un solo lugar.
            </p>
        </div>
    </div>

    <div class="features-section">
        <div class="container">
            <h2 class="section-title">¿Qué puedes hacer en AGROCONNECT?</h2>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">📤</div>
                    <h3>Subir Recetas</h3>
                    <p>Carga archivos PDF de recetas fitosanitarias de forma rápida y segura. El sistema procesa automáticamente toda la información.</p>
                    <a asp-controller="Account" asp-action="Login" class="feature-btn">
                        Comenzar <span>→</span>
                    </a>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">🔍</div>
                    <h3>Consultar Recetas</h3>
                    <p>Accede al historial completo de recetas cargadas. Busca por número RFD, fecha, solicitante o cualquier otro criterio.</p>
                    <a asp-controller="Account" asp-action="Login" class="feature-btn">
                        Comenzar <span>→</span>
                    </a>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">✅</div>
                    <h3>Aprobar Aplicaciones</h3>
                    <p>Los municipios pueden revisar y aprobar las solicitudes de aplicación de productos fitosanitarios en sus jurisdicciones.</p>
                    <a asp-controller="Account" asp-action="Login" class="feature-btn">
                        Comenzar <span>→</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="info-section">
        <div class="container">
            <div class="info-grid">
                <div class="info-card">
                    <div class="info-number">🌱</div>
                    <h3>Para Agricultores</h3>
                    <p>Gestiona tus recetas fitosanitarias digitalmente. Carga PDFs y accede a toda la información procesada automáticamente.</p>
                </div>

                <div class="info-card">
                    <div class="info-number">👨‍🔬</div>
                    <h3>Para Asesores</h3>
                    <p>Realiza el seguimiento de las recetas emitidas. Sistema integrado con el registro de asesores fitosanitarios.</p>
                </div>

                <div class="info-card">
                    <div class="info-number">🏛️</div>
                    <h3>Para Municipios</h3>
                    <p>Controla las aplicaciones en tu jurisdicción. Revisa puntos sensibles, lotes y condiciones de aplicación en tiempo real.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="cta-section">
        <div class="cta-content">
            <h2>¿Listo para comenzar?</h2>
            <p>Digitaliza tu gestión de recetas fitosanitarias hoy mismo</p>
            <div class="cta-buttons">
                <a asp-controller="Account" asp-action="Register" class="btn-primary-large">
                    📝 Crear Cuenta
                </a>
                <a asp-controller="Account" asp-action="Login" class="btn-secondary-large">
                    🔐 Iniciar Sesión
                </a>
            </div>
        </div>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
}
